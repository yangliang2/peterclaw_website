{
  "name": "peterclaw-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "quality:content": "node scripts/validate-content.mjs",
    "quality:hreflang": "node scripts/validate-hreflang.mjs",
    "health:content": "node scripts/content-health-report.mjs",
    "health:smoke": "node scripts/production-smoke-test.mjs",
    "build:embeddings": "node scripts/generate-embeddings.mjs",
    "build": "npm run build:embeddings && astro check && astro build && npm run quality:hreflang",
    "preview": "astro preview",
    "preview:e2e": "vite preview --outDir dist/client",
    "astro": "astro",
    "validate-schema": "tsx scripts/validate-schema.ts",
    "test:performance": "lhci autorun",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@resvg/resvg-js": "^2.6.2",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "^6.0.0",
    "astro-pagefind": "^2.0.0",
    "pagefind": "^1.5.2",
    "satori": "^0.26.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.13.0",
    "@playwright/test": "^1.60.0",
    "@types/jsdom": "^28.0.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.3"
  }
}
