---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);

const platforms = [
  {
    name: 'X',
    icon: 'M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z',
    href: `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`
  },
  {
    name: 'LinkedIn',
    icon: 'M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z',
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`
  }
];
---

<div class="social-share">
  <span class="share-label">Share:</span>
  <div class="share-links">
    {platforms.map((platform) => (
      <a
        href={platform.href}
        target="_blank"
        rel="noopener noreferrer"
        class="share-link"
        data-platform={platform.name}
        aria-label={`Share on ${platform.name}`}
      >
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
          <path d={platform.icon} />
        </svg>
      </a>
    ))}
  </div>
</div>

<script>
  function initSocialShareTracking() {
    const shareLinks = document.querySelectorAll('.share-link');
    shareLinks.forEach(link => {
      link.addEventListener('click', () => {
        const platform = link.getAttribute('data-platform');
        const url = window.location.href;
        window.trackEvent('social_share', { platform, url });
      });
    });
  }

  initSocialShareTracking();
  document.addEventListener('astro:after-swap', initSocialShareTracking);
</script>

<style>
  .social-share {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin: 3rem 0;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }

  .share-label {
    font-weight: 600;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .share-links {
    display: flex;
    gap: var(--space-md);
  }

  .share-link {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .share-link:hover {
    color: var(--color-primary);
  }
</style>
