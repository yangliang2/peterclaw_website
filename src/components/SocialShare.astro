---
import { getSiteUrl } from '@/config/site';

interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const siteUrl = getSiteUrl();
const domain = siteUrl.hostname;

const encodedTitle = encodeURIComponent(`${title} | ${domain}`);
const encodedUrl = encodeURIComponent(url);

const platforms = [
  {
    name: 'X',
    icon: 'M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z',
    href: `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`
  },
  {
    name: 'LinkedIn',
    icon: 'M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z',
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`
  },
  {
    name: 'Copy Link',
    icon: 'M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z',
    isCopy: true
  }
];
---

<div class="social-share">
  <span class="share-label">Share:</span>
  <div class="share-links">
    {platforms.map((platform) => (
      platform.isCopy ? (
        <button
          class="share-link copy-link"
          data-url={url}
          aria-label="Copy link to clipboard"
        >
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true" focusable="false">
            <path d={platform.icon} />
          </svg>
          <span class="copy-success-tip">Copied!</span>
        </button>
      ) : (
        <a
          href={platform.href}
          target="_blank"
          rel="noopener noreferrer"
          class="share-link"
          data-platform={platform.name}
          aria-label={`Share on ${platform.name}`}
        >
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true" focusable="false">
            <path d={platform.icon} />
          </svg>
        </a>
      )
    ))}
  </div>
</div>

<script>
  function initSocialShare() {
    const shareLinks = document.querySelectorAll('.share-link:not(.copy-link)');
    shareLinks.forEach(link => {
      link.addEventListener('click', () => {
        const platform = link.getAttribute('data-platform');
        const url = window.location.href;
        window.trackEvent?.('social_share', { platform, url });
      });
    });

    const copyBtn = document.querySelector('.copy-link');
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        const url = copyBtn.getAttribute('data-url') || window.location.href;
        try {
          await navigator.clipboard.writeText(url);
          copyBtn.classList.add('copied');
          setTimeout(() => {
            copyBtn.classList.remove('copied');
          }, 2000);
          
          window.trackEvent?.('social_share', { platform: 'Copy Link', url });
        } catch (err) {
          console.error('Failed to copy: ', err);
        }
      });
    }
  }

  initSocialShare();
  document.addEventListener('astro:after-swap', initSocialShare);
</script>

<style>
  .social-share {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin: 3rem 0;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }

  .share-label {
    font-weight: 600;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .share-links {
    display: flex;
    gap: var(--space-md);
  }

  .share-link {
    color: var(--color-text-muted);
    transition: all 0.2s;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    position: relative;
  }

  .share-link:hover {
    color: var(--color-primary);
  }

  .copy-success-tip {
    position: absolute;
    top: -2rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: var(--color-button-text);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
    white-space: nowrap;
  }

  .copy-link.copied .copy-success-tip {
    opacity: 1;
  }
</style>
