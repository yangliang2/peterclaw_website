---
import CTA from './CTA.astro';
import type { Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<footer class="article-footer">
  <hr />
  <CTA locale={locale} />
</footer>

<style>
  .article-footer {
    margin-top: 4rem;
  }

  hr {
    border: 0;
    border-top: 1px solid var(--color-line);
    margin: 4rem 0;
  }
</style>
