---
import type { Locale } from '@/lib/i18n';
import type { Project, ProjectsCopy } from '@/config/projects';
import type { GitHubProjectRepository } from '@/lib/github';
import { Image } from 'astro:assets';

interface Props {
  project: Project;
  locale: Locale;
  copy: ProjectsCopy;
  githubStats?: GitHubProjectRepository;
}

const { project, locale, copy, githubStats } = Astro.props;
const projectUrl = typeof project.url === 'string' ? project.url : project.url[locale];
const languageColors: Record<string, string> = {
  Astro: '#ff5d01',
  CSS: '#563d7c',
  JavaScript: '#f1e05a',
  TypeScript: '#3178c6',
  Python: '#3572a5',
  Go: '#00add8',
  Rust: '#dea584',
  Vue: '#41b883',
};
const numberFormatter = new Intl.NumberFormat(locale === 'en' ? 'en' : 'zh-CN', {
  notation: 'compact',
  maximumFractionDigits: 1,
});
const dateFormatter = new Intl.DateTimeFormat(locale === 'en' ? 'en' : 'zh-CN', {
  dateStyle: 'medium',
});
const languageColor = languageColors[githubStats?.language ?? ''] ?? '#8b949e';
---

<article class="project-card glass-card" data-tags={project.tags.join(' ')} data-github-repo={project.githubRepo}>
  <Image
    class="project-cover"
    src={project.coverImage}
    alt={project.coverAlt[locale]}
    width={640}
    height={360}
    format="svg"
    loading="lazy"
    decoding="async"
  />

  <div class="project-main">
    <div class="project-heading">
      <p class="project-tags">{project.tags.join(' / ')}</p>
      <span class:list={['status', `status-${project.status}`]}>{copy.status[project.status]}</span>
    </div>
    <h3>{project.title}</h3>
    <p>{project.description[locale]}</p>
  </div>

  {
    githubStats && (
      <div class="github-stats" aria-live="polite">
        <dl>
          <div>
            <dt>{copy.stars}</dt>
            <dd aria-label={`${githubStats.stars} ${copy.stars}`}>
              &#9733; {numberFormatter.format(githubStats.stars)}
            </dd>
          </div>
          <div>
            <dt>{copy.forks}</dt>
            <dd>{numberFormatter.format(githubStats.forks)}</dd>
          </div>
          <div>
            <dt>{copy.language}</dt>
            <dd class="language" style={`--language-color: ${languageColor}`}>
              {githubStats.language ?? '-'}
            </dd>
          </div>
          <div>
            <dt>{copy.updated}</dt>
            <dd>{dateFormatter.format(new Date(githubStats.updatedAt))}</dd>
          </div>
        </dl>
      </div>
    )
  }

  <div class="stack">
    <span>{copy.stack}</span>
    <ul>
      {project.stack.map((item) => <li>{item}</li>)}
    </ul>
  </div>

  <div class="project-links">
    {project.github && <a class="btn btn-secondary" href={project.github}>{copy.github}</a>}
    <a class="btn btn-primary" href={projectUrl}>{copy.visit}</a>
  </div>
</article>

<style>
  .project-card {
    display: grid;
    gap: var(--space-lg);
    max-width: none;
    padding: var(--space-md);
    margin: 0;
    transition:
      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      background 0.25s ease;
  }

  .project-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-3px);
    box-shadow: 0 14px 40px rgb(15 24 43 / 18%);
    background: var(--color-surface-hover, var(--gradient-glass));
  }

  .project-cover {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--color-soft-bg);
  }

  .project-main {
    display: grid;
    gap: var(--space-sm);
  }

  .project-main h3 {
    margin: 0;
    font-size: clamp(1.35rem, 3vw, 1.8rem);
  }

  .project-main > p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .project-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .project-tags {
    margin: 0;
    color: var(--color-secondary);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .status {
    flex-shrink: 0;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
  }

  .status-shipped {
    color: var(--color-primary);
    background: var(--color-primary-soft-bg);
  }

  .status-experiment {
    color: var(--color-secondary);
    background: var(--color-soft-bg);
  }

  .stack {
    display: grid;
    gap: var(--space-sm);
  }

  .github-stats {
    min-height: 4.9rem;
  }

  .github-stats-loading {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .github-stats dl {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    padding: var(--space-sm) 0;
    margin: 0;
    border-block: 1px solid var(--color-line);
  }

  .github-stats dt {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .github-stats dd {
    margin: 0.25rem 0 0;
    color: var(--color-text);
    font-size: 0.93rem;
    font-weight: 600;
  }

  .github-stats .language {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .github-stats .language::before {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: var(--language-color, #8b949e);
    content: '';
  }

  .stack span {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
  }

  .stack ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .stack li {
    padding: 0.35rem 0.7rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    color: var(--color-text);
    background: var(--color-primary-soft-bg);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .project-links .btn {
    min-width: 7rem;
  }

  @media (min-width: 760px) {
    .project-card {
      align-content: start;
      padding: var(--space-lg);
    }
  }
</style>
