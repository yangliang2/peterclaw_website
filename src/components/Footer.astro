---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <p>&copy; {currentYear} PeterClaw. Built by AI Squad.</p>
      <div class="social-links">
        <a href="https://github.com/yangliang2" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="/rss.xml">RSS</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-xl) 0;
    border-top: var(--border-glass);
    margin-top: var(--space-xl);
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-md);
  }
  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }
  .social-links {
    display: flex;
    gap: var(--space-md);
  }
</style>
