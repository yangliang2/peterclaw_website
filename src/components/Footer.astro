---
import type { Locale } from '@/lib/i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'zh' } = Astro.props;
const currentYear = new Date().getFullYear();
const nowHref = `/${locale}/now/`;
const copy = locale === 'zh'
  ? {
      newsletterLabel: '订阅更新',
      email: '电子邮箱',
      emailPlaceholder: '接收更新的电子邮箱',
      subscribe: '订阅',
      subscribed: '感谢订阅！',
    }
  : {
      newsletterLabel: 'Subscribe for updates',
      email: 'Email address',
      emailPlaceholder: 'Email for updates',
      subscribe: 'Subscribe',
      subscribed: 'Thanks for subscribing!',
    };
---

<footer class="footer" data-pagefind-ignore="all">
  <div class="container footer-content">
    <div class="footer-info">
      <p>&copy; {currentYear} PeterClaw. Built by AI Squad.</p>
      <div class="social-links">
        <a href="https://github.com/yangliang2" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="/rss.xml">RSS</a>
        <a href={nowHref}>Now</a>
      </div>
    </div>
    
    <div class="newsletter-box">
      <form class="newsletter-form" id="newsletter-footer" aria-label={copy.newsletterLabel}>
        <label class="visually-hidden" for="newsletter-email">{copy.email}</label>
        <input
          id="newsletter-email"
          name="email"
          type="email"
          autocomplete="email"
          placeholder={copy.emailPlaceholder}
          required
        />
        <button type="submit" class="btn-subscribe">{copy.subscribe}</button>
      </form>
      <p class="success" id="newsletter-success" role="status" aria-live="polite" hidden>{copy.subscribed}</p>
    </div>
  </div>
</footer>

<script>
  const form = document.getElementById('newsletter-footer') as HTMLFormElement;
  const status = document.getElementById('newsletter-success') as HTMLParagraphElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = (form.querySelector('input[type="email"]') as HTMLInputElement).value;
      if (email) {
        window.trackEvent('newsletter_subscribe', { location: 'footer' });
        form.hidden = true;
        status.hidden = false;
      }
    });
  }
</script>

<style>
  .footer {
    padding: var(--space-xl) 0;
    border-top: var(--border-glass);
    margin-top: var(--space-xl);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-xl);
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .footer-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer p {
    margin: 0;
  }

  .social-links {
    display: flex;
    gap: var(--space-md);
  }

  .newsletter-box {
    flex-shrink: 0;
  }

  .newsletter-form {
    display: flex;
    gap: 0.5rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }

  .newsletter-form input {
    background: var(--color-input-bg);
    border: var(--border-glass);
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.75rem;
    color: var(--color-text);
    font-size: 0.875rem;
    width: 200px;
  }

  .btn-subscribe {
    background: var(--color-action);
    color: var(--color-button-text);
    border: none;
    border-radius: var(--radius-sm);
    padding: 0.5rem 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .btn-subscribe:hover {
    opacity: 0.9;
  }

  .success {
    color: var(--color-secondary);
    margin: 0;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .footer-content {
      align-items: flex-start;
      flex-direction: column;
    }
    .newsletter-form input {
      width: 100%;
    }
  }
</style>
