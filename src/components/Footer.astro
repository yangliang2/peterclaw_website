---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-content">
    <p>&copy; {currentYear} PeterClaw. Built by AI Squad.</p>
    <div class="social-links">
      <a href="https://github.com/yangliang2" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="/rss.xml">RSS</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-xl) 0;
    border-top: var(--border-glass);
    margin-top: var(--space-xl);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .footer p {
    margin: 0;
  }

  .social-links {
    display: flex;
    gap: var(--space-md);
  }

  @media (max-width: 640px) {
    .footer-content {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
