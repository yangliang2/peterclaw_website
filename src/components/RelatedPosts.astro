---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { collectionPath, type Locale } from '@/lib/i18n';
import { resolveCoverAsset, tagCoverGradient } from '@/utils/cover';

type AnyCollectionEntry = CollectionEntry<'blog'> | CollectionEntry<'knowledge'>;

interface Props {
  locale: Locale;
  posts: AnyCollectionEntry[];
  collection?: 'blog' | 'knowledge';
}

const { locale, posts, collection = 'blog' } = Astro.props;
const heading = locale === 'zh' ? '相关文章' : 'Related posts';

const isBlogEntry = (entry: AnyCollectionEntry): entry is CollectionEntry<'blog'> => entry.collection === 'blog';

const clampText = (text: string, maxChars: number) => {
  const normalized = text.replace(/\s+/g, ' ').trim();
  if (normalized.length <= maxChars) return normalized;
  return `${normalized.slice(0, Math.max(0, maxChars - 1)).trim()}…`;
};

const coverAlt = (title: string) => (locale === 'zh' ? `${title} 封面图` : `${title} — cover image`);

const blogCoverMeta = (entry: CollectionEntry<'blog'>) => {
  const contentTypeCovers = {
    journal: 'journal.svg',
    review: 'review.svg',
    tutorial: 'tutorial.svg',
    toolbox: 'tutorial.svg',
    'case-study': 'tutorial.svg',
  } as const;

  const coverAsset =
    resolveCoverAsset(entry.data.cover) ??
    resolveCoverAsset(entry.data.contentType ? contentTypeCovers[entry.data.contentType] : undefined);
  const coverFormat = coverAsset?.src.endsWith('.svg') ? 'svg' : 'webp';
  const placeholderGradient = tagCoverGradient(entry.data.tags, entry.id);

  return { coverAsset, coverFormat, placeholderGradient };
};

const placeholderGradientFor = (tags: string[], id: string) => tagCoverGradient(tags, id);
---

{
  posts.length > 0 && (
    <aside class="related-posts" aria-label={heading}>
      <h2>{heading}</h2>
      <div class="related-list">
        {posts.map((post) => (
          <a class="related-card" href={collectionPath(locale, collection, post.id)}>
            <div class="thumb" aria-hidden="true">
              {(() => {
                if (isBlogEntry(post)) {
                  const { coverAsset, coverFormat, placeholderGradient } = blogCoverMeta(post);

                  return coverAsset ? (
                    <Image
                      class="thumb-image"
                      src={coverAsset}
                      alt={coverAlt(post.data.title)}
                      width={320}
                      height={180}
                      format={coverFormat}
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="thumb-placeholder" style={`background: ${placeholderGradient}`} />
                  );
                }

                const placeholderGradient = placeholderGradientFor(post.data.tags, post.id);
                return <div class="thumb-placeholder" style={`background: ${placeholderGradient}`} />;
              })()}
            </div>

            <div class="content">
              <span class="meta">
                {'publishedAt' in post.data && post.data.publishedAt ? post.data.publishedAt.toISOString().slice(0, 10) : ''}
              </span>
              <strong class="title">{post.data.title}</strong>
              <p class="desc">{clampText(post.data.description ?? '', 80)}</p>
            </div>
          </a>
        ))}
      </div>
    </aside>
  )
}

<style>
  .related-posts {
    margin-top: 3.5rem;
    padding-top: 0.5rem;
  }

  .related-posts h2 {
    margin: 0 0 1.25rem;
  }

  .related-list {
    display: grid;
    gap: 0.85rem;
  }

  .related-card {
    display: grid;
    grid-template-columns: 140px minmax(0, 1fr);
    gap: 0.9rem;
    padding: 1rem 1.25rem;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--gradient-glass);
    color: inherit;
    text-decoration: none;
  }

  .related-card:hover {
    border-color: var(--color-primary);
    background: var(--color-surface-hover);
  }

  .thumb {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--color-line);
    background: var(--color-soft-bg);
  }

  .thumb-image,
  .thumb-placeholder {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .content {
    min-width: 0;
    display: grid;
    align-content: start;
    gap: 0.35rem;
  }

  .title {
    color: var(--color-heading);
    font-size: 1rem;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }

  .desc {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.92rem;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }

  .meta {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.03em;
  }

  @media (max-width: 520px) {
    .related-card {
      grid-template-columns: 1fr;
    }

    .thumb {
      width: 100%;
    }
  }
</style>
