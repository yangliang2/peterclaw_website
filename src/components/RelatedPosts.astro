---
import type { CollectionEntry } from 'astro:content';
import { collectionPath, type Locale } from '@/lib/i18n';
import { ui } from '@/lib/i18n';

interface Props {
  locale: Locale;
  posts: CollectionEntry<'blog'>[];
}

const { locale, posts } = Astro.props;
const copy = ui[locale];

if (posts.length === 0) {
  return null;
}
---

<section class="related-posts" aria-labelledby="related-posts-heading">
  <h2 id="related-posts-heading">{copy.relatedPosts}</h2>
  <div class="related-posts__list">
    {
      posts.map((post) => (
        <a class="content-item" href={collectionPath(locale, 'blog', post.id)}>
          <span class="meta">{post.data.publishedAt.toISOString().slice(0, 10)}</span>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
        </a>
      ))
    }
  </div>
</section>

<style>
  .related-posts {
    max-width: 720px;
    margin: 4rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--color-line);
  }

  .related-posts h2 {
    margin: 0 0 1.5rem;
    font-size: 1.5rem;
  }

  .related-posts__list {
    display: grid;
    gap: 1rem;
  }

  .related-posts h3 {
    margin: 0;
    font-size: 1.25rem;
  }
</style>
