---
import type { CollectionEntry } from 'astro:content';
import { collectionPath, type Locale, ui } from '@/lib/i18n';

type AnyCollectionEntry = CollectionEntry<'blog'> | CollectionEntry<'knowledge'> | CollectionEntry<'product'>;

interface Props {
  locale: Locale;
  posts: AnyCollectionEntry[];
  collection?: 'blog' | 'knowledge' | 'product';
}

const { locale, posts, collection = 'blog' } = Astro.props;
if (posts.length === 0) {
  return;
}

const { relatedPosts: heading } = ui[locale];
---

<section class="related-posts" aria-labelledby="related-posts-heading">
  <h2 id="related-posts-heading">{heading}</h2>
  <div class="content-list">
    {
      posts.map((post) => (
        <a class="content-item" href={collectionPath(locale, collection, post.id)}>
          <span class="meta">
            {'publishedAt' in post.data && post.data.publishedAt
              ? post.data.publishedAt.toISOString().slice(0, 10)
              : ''}
          </span>
          <h3>{post.data.title}</h3>
          {'description' in post.data && post.data.description ? <p>{post.data.description}</p> : null}
        </a>
      ))
    }
  </div>
</section>

<style>
  .related-posts {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: var(--border-glass);
  }

  .related-posts h2 {
    margin: 0 0 0.5rem;
    font-size: 1.75rem;
  }

  .related-posts .content-list {
    margin-top: 1.5rem;
  }
</style>
