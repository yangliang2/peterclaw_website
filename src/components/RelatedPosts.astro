---
import type { CollectionEntry } from 'astro:content';
import { collectionPath, type Locale } from '@/lib/i18n';

type AnyCollectionEntry = CollectionEntry<'blog'> | CollectionEntry<'knowledge'> | CollectionEntry<'product'>;

interface Props {
  locale: Locale;
  posts: AnyCollectionEntry[];
  collection?: 'blog' | 'knowledge' | 'product';
}

const { locale, posts, collection = 'blog' } = Astro.props;
const heading = locale === 'zh' ? '相关文章' : 'Related posts';
---

{
  posts.length > 0 && (
    <aside class="related-posts" aria-label={heading}>
      <h2>{heading}</h2>
      <div class="related-list">
        {posts.map((post) => (
          <a href={collectionPath(locale, collection, post.id)} class="related-item">
            <span class="meta">{'publishedAt' in post.data && post.data.publishedAt ? post.data.publishedAt.toISOString().slice(0, 10) : ''}</span>
            <h3>{post.data.title}</h3>
            {'description' in post.data && post.data.description && (
              <p>{post.data.description}</p>
            )}
          </a>
        ))}
      </div>
    </aside>
  )
}

<style>
  .related-posts {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-line);
  }

  .related-posts h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--color-heading);
  }

  .related-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .related-item {
    display: grid;
    gap: 0.5rem;
    padding: 1.25rem;
    color: inherit;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--gradient-glass);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
  }

  .related-item:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.05);
  }

  .related-item h3 {
    margin: 0;
    font-size: 1.125rem;
    color: var(--color-heading);
  }

  .related-item p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-item .meta {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  @media (max-width: 480px) {
    .related-list {
      grid-template-columns: 1fr;
    }
  }
</style>
