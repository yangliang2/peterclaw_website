---
import { getCollection, type CollectionEntry } from 'astro:content';
import { collectionPath, type Locale, ui } from '@/lib/i18n';
import { popularArticles } from '@/config/popular';

interface Props {
  locale: Locale;
  limit?: number;
}

const { locale, limit = 5 } = Astro.props;
const copy = ui[locale];

const [blog, knowledge] = await Promise.all([
  getCollection('blog', (entry) => locale === entry.id.split('/')[0] && !entry.data.draft),
  getCollection('knowledge', (entry) => locale === entry.id.split('/')[0] && !entry.data.draft),
]);

const allEntries = new Map<string, CollectionEntry<'blog' | 'knowledge'>>();
for (const entry of blog) allEntries.set(`blog:${entry.id}`, entry);
for (const entry of knowledge) allEntries.set(`knowledge:${entry.id}`, entry);

const entries = popularArticles[locale]
  .map((item) => allEntries.get(`${item.collection}:${item.id}`))
  .filter((entry): entry is CollectionEntry<'blog' | 'knowledge'> => !!entry)
  .slice(0, limit);
---

{
  entries.length > 0 && (
    <section class="popular-section">
      <h2>{copy.popular}</h2>
      <ol class="popular-list">
        {entries.map((entry, index) => (
          <li class="popular-item">
            <a href={collectionPath(locale, entry.collection, entry.id)}>
              <span class="popular-rank">{index + 1}</span>
              <div class="popular-info">
                <h3>{entry.data.title}</h3>
                <p>{entry.data.description}</p>
              </div>
            </a>
          </li>
        ))}
      </ol>
    </section>
  )
}

<style>
  .popular-section {
    margin-top: var(--space-xl);
  }

  .popular-section h2 {
    margin-bottom: var(--space-lg);
  }

  .popular-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }

  .popular-item a {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--gradient-glass);
    color: inherit;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .popular-item a:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    background: var(--color-surface-hover);
  }

  .popular-rank {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-sm);
    background: var(--color-primary-soft-bg);
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
  }

  .popular-info {
    min-width: 0;
  }

  .popular-info h3 {
    margin: 0 0 0.25rem;
    font-size: 1rem;
    line-height: 1.4;
    color: var(--color-heading);
  }

  .popular-info p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .popular-item a {
      padding: 0.875rem 1rem;
      gap: 0.75rem;
    }

    .popular-rank {
      width: 1.75rem;
      height: 1.75rem;
      font-size: 0.8rem;
    }

    .popular-info h3 {
      font-size: 0.95rem;
    }

    .popular-info p {
      font-size: 0.8rem;
    }
  }
</style>
