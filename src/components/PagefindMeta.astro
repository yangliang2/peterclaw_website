---
import { getContentTypeLabel, type ContentSection } from '@/lib/search';
import type { Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
  section: ContentSection;
  contentType?: string;
  tags?: string[];
}

const { locale, section, contentType, tags = [] } = Astro.props;
const resolvedType =
  contentType ?? (section === 'knowledge' ? 'knowledge' : 'journal');
const typeLabel = getContentTypeLabel(resolvedType, section, locale);
---

<span data-pagefind-meta={`section:${section}`} hidden></span>
<span data-pagefind-meta={`content_type:${resolvedType}`} hidden></span>
<span data-pagefind-meta={`type_label:${typeLabel}`} hidden></span>
{tags.map((tag) => (
  <span data-pagefind-meta={`tag:${tag}`} hidden></span>
))}
