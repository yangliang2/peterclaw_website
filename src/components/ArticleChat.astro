---
import { ui, type Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
  articleContent: string;
}

const { locale, articleContent } = Astro.props;
const copy = ui[locale];
// Truncate at build time so the payload embedded in HTML stays bounded
const content = articleContent.slice(0, 6000);
const chatConfig = JSON.stringify({
  locale,
  messages: {
    submitting: copy.chatSubmitting,
    submitLabel: copy.chatSubmit,
    invalid: copy.chatErrorInvalid,
    rateLimit: copy.chatErrorRateLimit,
    quota: copy.chatErrorQuota,
    timeout: copy.chatErrorTimeout,
    generic: copy.chatErrorGeneric,
    you: copy.chatYou,
    ai: copy.chatAI,
  },
});
const chatPayload = JSON.stringify(content);
---

<details class="article-chat glass-card" aria-label={copy.chatPrompt}>
  <summary>
    <span class="chat-summary-text">{copy.chatPrompt}</span>
    <span class="chat-context-badge">{copy.chatContextHint}</span>
  </summary>
  <div class="article-chat-body">
    <p class="article-chat-desc">{copy.chatDescription}</p>
    <div class="chat-presets" data-chat-presets>
      <button type="button" class="chat-preset-btn">{copy.chatSuggest1}</button>
      <button type="button" class="chat-preset-btn">{copy.chatSuggest2}</button>
      <button type="button" class="chat-preset-btn">{copy.chatSuggest3}</button>
    </div>
    <div class="chat-history" data-chat-history hidden aria-live="polite"></div>
    <p class="article-chat-status" data-chat-status role="status" aria-live="polite" hidden></p>
    <form class="article-chat-form" data-chat-form novalidate>
      <label class="article-chat-field">
        <textarea
          name="question"
          rows="2"
          placeholder={copy.chatPlaceholder}
          required
          maxlength="500"
        ></textarea>
      </label>
      <div class="article-chat-actions">
        <button class="btn btn-primary" type="submit" data-chat-submit>{copy.chatSubmit}</button>
        <button class="btn" type="button" data-chat-clear hidden>{copy.chatClearHistory}</button>
      </div>
    </form>
  </div>
  <script type="application/json" data-article-chat-payload set:html={chatPayload}></script>
  <script type="application/json" data-article-chat-config set:html={chatConfig}></script>
</details>

<script is:inline>
  (function () {
    function loadArticleChat() {
      if (document.querySelector('script[data-article-chat-loader]')) return;
      const script = document.createElement('script');
      script.src = '/article-chat.js';
      script.async = true;
      script.dataset.articleChatLoader = 'true';
      document.body.appendChild(script);
    }

    document.querySelectorAll('.article-chat').forEach((details) => {
      if (!(details instanceof HTMLDetailsElement)) return;
      details.addEventListener('toggle', () => {
        if (details.open) loadArticleChat();
      });
      details.addEventListener(
        'focusin',
        () => {
          if (details.open) loadArticleChat();
        },
        { once: true },
      );
    });
  })();
</script>

<style>
  .article-chat {
    max-width: 720px;
    margin: var(--space-xl) auto 0;
    padding: 0;
  }

  .article-chat summary {
    cursor: pointer;
    padding: var(--space-lg);
    color: var(--color-heading);
    font-size: 1.125rem;
    font-weight: 600;
    list-style-position: inside;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .chat-summary-text {
    flex: 1;
  }

  .chat-context-badge {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.2em 0.65em;
    border-radius: 999px;
    border: var(--border-glass);
    background: var(--color-soft-bg);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .article-chat[open] summary {
    border-bottom: var(--border-glass);
  }

  .article-chat-body {
    padding: var(--space-lg);
  }

  .article-chat-desc {
    margin: 0 0 var(--space-md);
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .chat-presets {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--space-md);
  }

  .chat-preset-btn {
    padding: 0.3em 0.75em;
    border: var(--border-glass);
    border-radius: 999px;
    background: transparent;
    color: var(--color-text-muted);
    font: inherit;
    font-size: 0.85rem;
    cursor: pointer;
    line-height: 1.4;
    transition: border-color 0.15s, color 0.15s;
  }

  .chat-preset-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .chat-history {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .chat-pair {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .chat-message {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .chat-message-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  .chat-message--user .chat-message-label {
    color: var(--color-primary);
  }

  .chat-message--user .chat-message-content {
    padding: 0.55rem 0.85rem;
    border-left: 3px solid var(--color-primary);
    background: var(--color-soft-bg);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    color: var(--color-text);
    white-space: pre-wrap;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .chat-message--ai .chat-message-content {
    padding: 0.25rem 0;
    color: var(--color-article);
    line-height: 1.7;
    white-space: pre-wrap;
    font-size: 0.95rem;
  }

  .chat-message--ai.is-streaming .chat-message-content::after {
    content: '▊';
    animation: chat-blink 1s step-end infinite;
    margin-left: 1px;
    color: var(--color-primary);
  }

  @keyframes chat-blink {
    50% { opacity: 0; }
  }

  .article-chat-form {
    display: grid;
    gap: var(--space-md);
  }

  .article-chat-field textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--color-input-bg);
    color: var(--color-text);
    font: inherit;
    resize: vertical;
  }

  .article-chat-field textarea:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .article-chat-actions {
    display: flex;
    gap: var(--space-sm);
    align-items: center;
  }

  .article-chat-form .btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  .article-chat-status {
    margin: 0 0 var(--space-md);
    font-size: 0.95rem;
  }

  .article-chat-status.is-error {
    color: var(--color-error);
  }
</style>
