---
import { getCollection } from 'astro:content';
import PagefindConfig from 'astro-pagefind/components/PagefindConfig.astro';
import type { Locale } from '@/lib/i18n';
import { ui } from '@/lib/i18n';
import { isSearchFilterType, type SearchFilterType } from '@/lib/search';
import resultTemplate from '@/assets/pagefind-result-template.html?raw';
import PopularArticles from '@/components/PopularArticles.astro';

interface Props {
  locale: Locale;
  compact?: boolean;
}

const { locale, compact = false } = Astro.props;
const copy = ui[locale];
const initialQuery = Astro.url.searchParams.get('q') ?? '';
const rawType = Astro.url.searchParams.get('type');
const initialType: SearchFilterType = isSearchFilterType(rawType) ? rawType : 'all';
const initialTag = Astro.url.searchParams.get('tag') ?? '';

const [blog, knowledge] = await Promise.all([
  getCollection('blog', (entry) => locale === entry.id.split('/')[0] && !entry.data.draft),
  getCollection('knowledge', (entry) => locale === entry.id.split('/')[0] && !entry.data.draft),
]);

const tagCounts = new Map<string, number>();
for (const entry of [...blog, ...knowledge]) {
  for (const tag of entry.data.tags ?? []) {
    const key = String(tag).trim();
    if (!key) continue;
    tagCounts.set(key, (tagCounts.get(key) ?? 0) + 1);
  }
}

const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 24)
  .map(([tag, count]) => ({ tag, count }));

const filterTabs: { id: SearchFilterType; label: string }[] = [
  { id: 'all', label: copy.searchFilterAll },
  { id: 'blog', label: copy.searchFilterBlog },
  { id: 'knowledge', label: copy.searchFilterKnowledge },
  { id: 'review', label: copy.searchFilterReview },
];

const pagefindResultTemplate = `<script is:inline type="text/pagefind-template" data-template="result">${resultTemplate}</script>`;
---

<div
  class:list={['search-root', { 'search-root--compact': compact }]}
  data-locale={locale}
  data-initial-query={initialQuery}
  data-initial-type={initialType}
  data-initial-tag={initialTag}
>
  <div class="search-filters" role="tablist" aria-label={copy.searchTitle}>
    {
      filterTabs.map((tab) => (
        <button
          type="button"
          class:list={['search-filter-tab', { active: tab.id === initialType }]}
          role="tab"
          aria-selected={tab.id === initialType ? 'true' : 'false'}
          data-filter-type={tab.id}
        >
          {tab.label}
        </button>
      ))
    }
  </div>

  <div class="search-tag-entry">
    <a class="search-tag-entry-link" href="#browse-by-tag">
      {copy.searchBrowseByTag}
    </a>
  </div>

  <PagefindConfig instance="site-search" />
  <pagefind-searchbox
    instance="site-search"
    class="pagefind-ui"
    placeholder={copy.searchPlaceholder}
    {...(initialQuery ? { 'initial-query': initialQuery } : {})}
  >
    <Fragment set:html={pagefindResultTemplate} />
  </pagefind-searchbox>

  <section id="browse-by-tag" class="search-tags" aria-label={copy.searchBrowseByTag}>
    <h2 class="search-tags-title">{copy.searchBrowseByTag}</h2>
    <div class="search-tags-grid">
      {topTags.map(({ tag, count }) => (
        <button type="button" class="search-tag-chip" data-search-tag={tag}>
          <span class="search-tag-chip__label">{tag}</span>
          <span class="search-tag-chip__count">{count}</span>
        </button>
      ))}
    </div>
  </section>

  <section class="search-empty" hidden aria-live="polite">
    <div class="search-empty-card">
      <h2 class="search-empty-title">{copy.searchEmptyTitle}</h2>
      <p class="search-empty-desc">{copy.searchEmptyDescription}</p>
      <PopularArticles locale={locale} />
      <div class="search-empty-tags">
        <h3 class="search-empty-tags-title">{copy.searchEmptyTagsTitle}</h3>
        <div class="search-tags-grid">
          {topTags.slice(0, 12).map(({ tag, count }) => (
            <button type="button" class="search-tag-chip" data-search-tag={tag}>
              <span class="search-tag-chip__label">{tag}</span>
              <span class="search-tag-chip__count">{count}</span>
            </button>
          ))}
        </div>
      </div>
    </div>
  </section>
</div>

<script>
  import { getInstanceManager } from '@pagefind/component-ui';
  import {
    isSearchFilterType,
    pagefindFiltersForType,
    type SearchFilterType,
  } from '@/lib/search';

  const INSTANCE_NAME = 'site-search';

  function getSearchRoot() {
    return document.querySelector<HTMLElement>('.search-root');
  }

  function getActiveTag(root: HTMLElement): string {
    return root.dataset.activeTag ?? '';
  }

  function getActiveFilterType(root: HTMLElement): SearchFilterType {
    const active = root.querySelector<HTMLButtonElement>('.search-filter-tab.active');
    const type = active?.dataset.filterType ?? 'all';
    return isSearchFilterType(type) ? type : 'all';
  }

  function syncUrlParams(root: HTMLElement) {
    const input = root.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
    const query = input?.value.trim() ?? '';
    const type = getActiveFilterType(root);
    const tag = getActiveTag(root);
    const params = new URLSearchParams();

    if (query) params.set('q', query);
    if (type !== 'all') params.set('type', type);
    if (tag) params.set('tag', tag);

    const next = params.toString();
    const nextUrl = next ? `${window.location.pathname}?${next}` : window.location.pathname;
    window.history.replaceState({}, '', nextUrl);
  }

  function buildCombinedFilters(type: SearchFilterType, tag: string) {
    const base = pagefindFiltersForType(type);
    if (!tag) return base;
    return { ...base, tag: [tag] };
  }

  function applyFilterType(root: HTMLElement, type: SearchFilterType) {
    root.querySelectorAll<HTMLButtonElement>('.search-filter-tab').forEach((tab) => {
      const isActive = tab.dataset.filterType === type;
      tab.classList.toggle('active', isActive);
      tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });

    const manager = getInstanceManager();
    const instance = manager.getInstance(INSTANCE_NAME);
    const input = root.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
    const term = input?.value.trim() ?? '';

    instance.triggerSearchWithFilters(term, buildCombinedFilters(type, getActiveTag(root)));
    syncUrlParams(root);
  }

  function applyTag(root: HTMLElement, tag: string) {
    const manager = getInstanceManager();
    const instance = manager.getInstance(INSTANCE_NAME);
    const input = root.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
    const term = input?.value.trim() ?? '';
    root.dataset.activeTag = tag;

    instance.triggerSearchWithFilters(term, buildCombinedFilters(getActiveFilterType(root), tag));
    syncUrlParams(root);
  }

  function getInitialQuery(root: HTMLElement): string {
    const urlQuery = new URLSearchParams(window.location.search).get('q') ?? '';
    return (urlQuery || root.dataset.initialQuery || '').trim();
  }

  function applyInitialQuery(root: HTMLElement) {
    const query = getInitialQuery(root);
    if (!query || root.dataset.initialQueryApplied === 'true') return;

    const manager = getInstanceManager();
    const instance = manager.getInstance(INSTANCE_NAME);
    const input = root.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
    if (input) {
      input.value = query;
    }

    root.dataset.initialQueryApplied = 'true';
    instance.triggerSearchWithFilters(
      query,
      buildCombinedFilters(getActiveFilterType(root), getActiveTag(root))
    );
  }

  function initSearchFilters() {
    const root = getSearchRoot();
    if (!root || root.dataset.filtersReady === 'true') return;

    const initialType = root.dataset.initialType;
    const filterType: SearchFilterType =
      initialType && isSearchFilterType(initialType) ? initialType : 'all';
    const initialTag = (root.dataset.initialTag ?? '').trim();
    root.dataset.activeTag = initialTag;

    root.dataset.filtersReady = 'true';

    root.querySelectorAll<HTMLButtonElement>('.search-filter-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const type = tab.dataset.filterType;
        if (!type || !isSearchFilterType(type)) return;
        applyFilterType(root, type);
      });
    });

    root.querySelectorAll<HTMLButtonElement>('[data-search-tag]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const tag = (btn.dataset.searchTag ?? '').trim();
        if (!tag) return;
        applyTag(root, tag);
      });
    });

    window.setTimeout(() => {
      if (filterType !== 'all') {
        applyFilterType(root, filterType);
      }
      if (initialTag) {
        applyTag(root, initialTag);
      }
      applyInitialQuery(root);
    }, 0);
  }

  function isEmptyResults(root: HTMLElement): boolean {
    const queryInput = root.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
    const query = queryInput?.value.trim() ?? '';
    if (!query) return false;

    const results =
      root.querySelectorAll('.pagefind-ui__result, .pf-result').length;
    return results === 0;
  }

  function syncEmptyState(root: HTMLElement) {
    const empty = root.querySelector<HTMLElement>('.search-empty');
    if (!empty) return;
    empty.hidden = !isEmptyResults(root);
  }

  function initEmptyStateObserver() {
    const root = getSearchRoot();
    if (!root) return;

    const resultsContainer =
      root.querySelector<HTMLElement>('.pagefind-ui__results') ??
      root.querySelector<HTMLElement>('.pagefind-ui__results-area') ??
      root;

    const observer = new MutationObserver(() => syncEmptyState(root));
    observer.observe(resultsContainer, { subtree: true, childList: true, attributes: true });
    root.addEventListener('input', () => syncEmptyState(root));
    window.setTimeout(() => syncEmptyState(root), 0);
  }

  function maybeAutoFocus() {
    const root = getSearchRoot();
    if (!root) return;
    const params = new URLSearchParams(window.location.search);
    if (params.get('focus') !== '1') return;
    window.setTimeout(() => {
      const input = root.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
      input?.focus();
      input?.select();
    }, 0);
  }

  function initSearchTracking() {
    const root = getSearchRoot();
    if (!root) return;

    let searchTimeout: ReturnType<typeof setTimeout>;

    root.addEventListener('input', (event) => {
      const input = event.target as HTMLInputElement;
      if (!input.classList.contains('pagefind-ui__search-input')) return;

      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        const query = input.value.trim();
        syncUrlParams(root);
        if (query.length > 2) {
          window.trackEvent?.('search', { query, type: getActiveFilterType(root) });
        }
      }, 1000);
    });

    root.addEventListener('click', (event) => {
      const resultLink = (event.target as HTMLElement).closest(
        '.pagefind-ui__result-link, .pf-result-link',
      ) as HTMLAnchorElement | null;
      if (!resultLink) return;

      const queryInput = root.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
      window.trackEvent?.('search_result_click', {
        query: queryInput?.value || '',
        title: resultLink.innerText,
        url: resultLink.getAttribute('href'),
        type: getActiveFilterType(root),
      });
    });
  }

  initSearchFilters();
  initSearchTracking();
  initEmptyStateObserver();
  maybeAutoFocus();
  document.addEventListener('astro:page-load', () => {
    const root = getSearchRoot();
    if (root) {
      root.dataset.filtersReady = 'false';
      root.dataset.initialQueryApplied = 'false';
    }
    initSearchFilters();
    initSearchTracking();
    initEmptyStateObserver();
    maybeAutoFocus();
  });
</script>

<style>
  .search-root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--color-primary);
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-background: var(--color-surface);
    --pagefind-ui-border: var(--color-line);
    --pagefind-ui-tag: var(--color-surface);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: var(--radius-md);
    --pagefind-ui-image-border-radius: var(--radius-sm);
    --pagefind-ui-font: var(--font-sans);
  }

  .search-filters {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    overflow-x: auto;
    padding-bottom: 0.25rem;
    scrollbar-width: none;
  }

  .search-filters::-webkit-scrollbar {
    display: none;
  }

  .search-filter-tab {
    flex-shrink: 0;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: var(--color-surface);
    color: var(--color-text-muted);
    font: inherit;
    font-size: 0.9rem;
    padding: 0.45rem 0.95rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .search-filter-tab:hover,
  .search-filter-tab.active {
    border-color: var(--color-primary);
    color: var(--color-heading);
    background: var(--color-primary-soft-bg);
  }

  .search-root :global(.pagefind-ui),
  .search-root :global(pagefind-searchbox) {
    width: 100%;
    display: block;
  }

  .search-root :global(.pagefind-ui__search-input),
  .search-root :global(.pf-searchbox-input) {
    background: var(--color-input-bg);
    color: var(--color-text);
    border-color: var(--color-line);
    font-size: 1.05rem;
    padding: 0.85rem 1rem;
  }

  .search-root :global(.pagefind-ui__result),
  .search-root :global(.pf-result-card) {
    border-color: var(--color-line);
    background: var(--gradient-glass);
  }

  .search-root :global(.pagefind-ui__result-title),
  .search-root :global(.pf-result-title) {
    color: var(--color-heading);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .search-root :global(.pagefind-ui__result-excerpt),
  .search-root :global(.pf-result-excerpt) {
    color: var(--color-text-muted);
  }

  .search-root :global(.search-type-badge) {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    background: var(--color-primary-soft-bg);
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .search-root--compact {
    max-width: 100%;
  }

  .search-root--compact .search-filters {
    margin-bottom: 0.75rem;
  }

  .search-tag-entry {
    margin: 0 0 0.75rem;
  }

  .search-tag-entry-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-text-muted);
    font-weight: 600;
    text-decoration: none;
  }

  .search-tag-entry-link:hover {
    color: var(--color-text);
  }

  .search-tags {
    margin-top: var(--space-xl);
  }

  .search-tags-title {
    margin: 0 0 0.75rem;
    font-size: 1.05rem;
  }

  .search-tags-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .search-tag-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--color-line);
    background: var(--color-surface);
    color: var(--color-text);
    cursor: pointer;
    font: inherit;
    transition: all 0.2s ease;
  }

  .search-tag-chip:hover {
    border-color: var(--color-primary);
    background: var(--color-primary-soft-bg);
  }

  .search-tag-chip__count {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .search-empty {
    margin-top: var(--space-xl);
  }

  .search-empty-card {
    padding: 1.25rem 1.25rem 0.5rem;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--gradient-glass);
  }

  .search-empty-title {
    margin: 0 0 0.35rem;
  }

  .search-empty-desc {
    margin: 0 0 1rem;
    color: var(--color-text-muted);
  }

  .search-empty-tags {
    margin-top: var(--space-xl);
  }

  .search-empty-tags-title {
    margin: 0 0 0.75rem;
    font-size: 1rem;
  }
</style>
