---
import PagefindSearch from 'astro-pagefind/components/Search.astro';
import type { Locale } from '@/lib/i18n';
import { ui } from '@/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = ui[locale];
const initialQuery = Astro.url.searchParams.get('q') ?? '';
---

<div class="search-root">
  <PagefindSearch
    instance="site-search"
    className="pagefind-ui"
    searchboxOptions={{
      placeholder: copy.searchPlaceholder,
      ...(initialQuery ? { 'initial-query': initialQuery } : {}),
    }}
  />
</div>

<script>
  function initSearchTracking() {
    const searchRoot = document.querySelector('.search-root');
    if (!searchRoot) return;

    let searchTimeout: ReturnType<typeof setTimeout>;

    // Track search input with debouncing
    searchRoot.addEventListener('input', (event) => {
      const input = event.target as HTMLInputElement;
      if (!input.classList.contains('pagefind-ui__search-input')) return;

      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        const query = input.value.trim();
        if (query.length > 2) {
          window.trackEvent('search', { query });
        }
      }, 1000);
    });

    // Track result clicks
    searchRoot.addEventListener('click', (event) => {
      const resultLink = (event.target as HTMLElement).closest('.pagefind-ui__result-link') as HTMLAnchorElement;
      if (!resultLink) return;

      const queryInput = searchRoot.querySelector('.pagefind-ui__search-input') as HTMLInputElement;
      const title = resultLink.innerText;
      const url = resultLink.getAttribute('href');

      window.trackEvent('search_result_click', {
        query: queryInput?.value || '',
        title,
        url
      });
    });
  }

  // Initialize on load and on view transitions (if used)
  initSearchTracking();
  document.addEventListener('astro:after-swap', initSearchTracking);
</script>

<style>
  .search-root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--color-primary);
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-background: var(--color-surface);
    --pagefind-ui-border: var(--color-line);
    --pagefind-ui-tag: var(--color-surface);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: var(--radius-md);
    --pagefind-ui-image-border-radius: var(--radius-sm);
    --pagefind-ui-font: var(--font-sans);
  }

  .search-root :global(.pagefind-ui) {
    width: 100%;
  }

  .search-root :global(.pagefind-ui__search-input) {
    background: var(--color-input-bg);
    color: var(--color-text);
    border-color: var(--color-line);
    font-size: 1.05rem;
    padding: 0.85rem 1rem;
  }

  .search-root :global(.pagefind-ui__result) {
    border-color: var(--color-line);
    background: var(--gradient-glass);
  }

  .search-root :global(.pagefind-ui__result-title) {
    color: var(--color-heading);
  }

  .search-root :global(.pagefind-ui__result-excerpt) {
    color: var(--color-text-muted);
  }
</style>
