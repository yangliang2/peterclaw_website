---
import PagefindConfig from 'astro-pagefind/components/PagefindConfig.astro';
import PopularArticles from '@/components/PopularArticles.astro';
import type { Locale } from '@/lib/i18n';
import { ui } from '@/lib/i18n';
import { isSearchFilterType, type SearchFilterType } from '@/lib/search';
import resultTemplate from '@/assets/pagefind-result-template.html?raw';

interface Props {
  locale: Locale;
  compact?: boolean;
}

const { locale, compact = false } = Astro.props;
const copy = ui[locale];
const initialQuery = Astro.url.searchParams.get('q') ?? '';
const rawType = Astro.url.searchParams.get('type');
const initialType: SearchFilterType = isSearchFilterType(rawType) ? rawType : 'all';

const filterTabs: { id: SearchFilterType; label: string }[] = [
  { id: 'all', label: copy.searchFilterAll },
  { id: 'blog', label: copy.searchFilterBlog },
  { id: 'knowledge', label: copy.searchFilterKnowledge },
  { id: 'review', label: copy.searchFilterReview },
];

const pagefindResultTemplate = `<script is:inline type="text/pagefind-template" data-template="result">${resultTemplate}</script>`;
---

<div
  class:list={['search-root', { 'search-root--compact': compact }]}
  data-locale={locale}
  data-initial-type={initialType}
>
  <div class="search-filters" role="tablist" aria-label={copy.searchTitle}>
    {
      filterTabs.map((tab) => (
        <button
          type="button"
          class:list={['search-filter-tab', { active: tab.id === initialType }]}
          role="tab"
          aria-selected={tab.id === initialType ? 'true' : 'false'}
          data-filter-type={tab.id}
        >
          {tab.label}
        </button>
      ))
    }
  </div>

  <PagefindConfig instance="site-search" />
  <pagefind-searchbox
    instance="site-search"
    class="pagefind-ui"
    placeholder={copy.searchPlaceholder}
    {...(initialQuery ? { 'initial-query': initialQuery } : {})}
  >
    <Fragment set:html={pagefindResultTemplate} />
  </pagefind-searchbox>

  <section class="search-empty" hidden aria-live="polite">
    <h2 class="search-empty__title">{copy.searchNoResultsTitle}</h2>
    <p class="search-empty__hint">{copy.searchNoResultsHint}</p>
    <PopularArticles locale={locale} />
  </section>
</div>

<script>
  import { getInstanceManager } from '@pagefind/component-ui';
  import type { PagefindSearchResult } from '@pagefind/component-ui';
  import {
    isSearchFilterType,
    pagefindFiltersForType,
    type SearchFilterType,
  } from '@/lib/search';

  const INSTANCE_NAME = 'site-search';
  const HIGHLIGHT_ATTR = 'data-search-highlight';

  function getSearchRoot() {
    return document.querySelector<HTMLElement>('.search-root');
  }

  function getEmptyState(root: HTMLElement) {
    return root.querySelector<HTMLElement>('.search-empty');
  }

  function setEmptyStateVisible(root: HTMLElement, visible: boolean) {
    const empty = getEmptyState(root);
    if (!empty) return;
    empty.toggleAttribute('hidden', !visible);
  }

  function getActiveFilterType(root: HTMLElement): SearchFilterType {
    const active = root.querySelector<HTMLButtonElement>('.search-filter-tab.active');
    const type = active?.dataset.filterType ?? 'all';
    return isSearchFilterType(type) ? type : 'all';
  }

  function escapeRegExp(value: string) {
    return value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  function normalizeQueryTerms(query: string): string[] {
    const raw = query
      .trim()
      .split(/\s+/)
      .map((t) => t.trim())
      .filter(Boolean);

    const unique: string[] = [];
    for (const term of raw) {
      if (term.length < 2) continue;
      if (unique.includes(term)) continue;
      unique.push(term);
      if (unique.length >= 6) break;
    }
    return unique;
  }

  function unwrapHighlights(container: HTMLElement) {
    container.querySelectorAll(`mark[${HIGHLIGHT_ATTR}]`).forEach((mark) => {
      const parent = mark.parentNode;
      if (!parent) return;
      parent.replaceChild(document.createTextNode(mark.textContent ?? ''), mark);
      parent.normalize();
    });
  }

  function highlightInContainer(container: HTMLElement, terms: string[]) {
    if (terms.length === 0) return;

    unwrapHighlights(container);

    const pattern = new RegExp(`(${terms.map(escapeRegExp).join('|')})`, 'gi');
    const walker = document.createTreeWalker(container, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        const parent = node.parentElement;
        if (!parent) return NodeFilter.FILTER_REJECT;
        const tag = parent.tagName;
        if (tag === 'SCRIPT' || tag === 'STYLE' || tag === 'MARK') {
          return NodeFilter.FILTER_REJECT;
        }
        if (!node.nodeValue || !node.nodeValue.trim()) {
          return NodeFilter.FILTER_REJECT;
        }
        return NodeFilter.FILTER_ACCEPT;
      },
    });

    const textNodes: Text[] = [];
    while (walker.nextNode()) {
      textNodes.push(walker.currentNode as Text);
    }

    for (const node of textNodes) {
      const text = node.nodeValue ?? '';
      if (!pattern.test(text)) continue;
      pattern.lastIndex = 0;

      const frag = document.createDocumentFragment();
      let lastIndex = 0;
      let match: RegExpExecArray | null;
      while ((match = pattern.exec(text)) !== null) {
        const start = match.index;
        const end = start + match[0].length;
        if (start > lastIndex) frag.append(text.slice(lastIndex, start));
        const mark = document.createElement('mark');
        mark.setAttribute(HIGHLIGHT_ATTR, 'true');
        mark.textContent = text.slice(start, end);
        frag.append(mark);
        lastIndex = end;
      }
      if (lastIndex < text.length) frag.append(text.slice(lastIndex));

      node.parentNode?.replaceChild(frag, node);
    }
  }

  function applyHighlights(root: HTMLElement, query: string) {
    const terms = normalizeQueryTerms(query);
    if (terms.length === 0) {
      root.querySelectorAll<HTMLElement>('.pf-result-card, .pagefind-ui__result').forEach((card) => {
        unwrapHighlights(card);
      });
      return;
    }

    root
      .querySelectorAll<HTMLElement>('.pf-result-card, .pagefind-ui__result')
      .forEach((card) => highlightInContainer(card, terms));
  }

  function syncUrlParams(root: HTMLElement) {
    const input = root.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
    const query = input?.value.trim() ?? '';
    const type = getActiveFilterType(root);
    const params = new URLSearchParams();

    if (query) params.set('q', query);
    if (type !== 'all') params.set('type', type);

    const next = params.toString();
    const nextUrl = next ? `${window.location.pathname}?${next}` : window.location.pathname;
    window.history.replaceState({}, '', nextUrl);
  }

  function applyFilterType(root: HTMLElement, type: SearchFilterType) {
    root.querySelectorAll<HTMLButtonElement>('.search-filter-tab').forEach((tab) => {
      const isActive = tab.dataset.filterType === type;
      tab.classList.toggle('active', isActive);
      tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });

    const manager = getInstanceManager();
    const instance = manager.getInstance(INSTANCE_NAME);
    const input = root.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
    const term = input?.value.trim() ?? '';

    instance.triggerSearchWithFilters(term, pagefindFiltersForType(type));
    syncUrlParams(root);
  }

  function initEmptyStateAndHighlighting() {
    const root = getSearchRoot();
    if (!root || root.dataset.resultsHookReady === 'true') return;

    const manager = getInstanceManager();
    const instance = manager.getInstance(INSTANCE_NAME);

    root.dataset.resultsHookReady = 'true';

    instance.on(
      'results',
      (results) => {
        const parsed = results as PagefindSearchResult;
        const input = root.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
        const query = input?.value.trim() ?? '';
        const hasQuery = query.length > 0;
        const empty =
          hasQuery && Array.isArray(parsed?.results) && parsed.results.length === 0;
        setEmptyStateVisible(root, empty);

        if (!hasQuery) return;
        requestAnimationFrame(() => requestAnimationFrame(() => applyHighlights(root, query)));
      },
      root,
    );

    instance.on(
      'search',
      () => {
        setEmptyStateVisible(root, false);
      },
      root,
    );
  }

  function initSearchFilters() {
    const root = getSearchRoot();
    if (!root || root.dataset.filtersReady === 'true') return;

    const initialType = root.dataset.initialType;
    const filterType: SearchFilterType =
      initialType && isSearchFilterType(initialType) ? initialType : 'all';

    root.dataset.filtersReady = 'true';

    root.querySelectorAll<HTMLButtonElement>('.search-filter-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const type = tab.dataset.filterType;
        if (!type || !isSearchFilterType(type)) return;
        applyFilterType(root, type);
      });
    });

    window.setTimeout(() => {
      if (filterType !== 'all') {
        applyFilterType(root, filterType);
      }
    }, 0);
  }

  function initSearchTracking() {
    const root = getSearchRoot();
    if (!root) return;

    let searchTimeout: ReturnType<typeof setTimeout>;

    root.addEventListener('input', (event) => {
      const input = event.target as HTMLInputElement;
      if (!input.classList.contains('pagefind-ui__search-input')) return;

      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        const query = input.value.trim();
        syncUrlParams(root);
        if (query.length > 2) {
          window.trackEvent('search', { query, type: getActiveFilterType(root) });
        }
      }, 1000);
    });

    root.addEventListener('click', (event) => {
      const resultLink = (event.target as HTMLElement).closest(
        '.pagefind-ui__result-link, .pf-result-link',
      ) as HTMLAnchorElement | null;
      if (!resultLink) return;

      const queryInput = root.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
      window.trackEvent('search_result_click', {
        query: queryInput?.value || '',
        title: resultLink.innerText,
        url: resultLink.getAttribute('href'),
        type: getActiveFilterType(root),
      });
    });
  }

  initSearchFilters();
  initEmptyStateAndHighlighting();
  initSearchTracking();
  document.addEventListener('astro:after-swap', () => {
    const root = getSearchRoot();
    if (root) root.dataset.filtersReady = 'false';
    if (root) root.dataset.resultsHookReady = 'false';
    initSearchFilters();
    initEmptyStateAndHighlighting();
    initSearchTracking();
  });
</script>

<style>
  .search-root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--color-primary);
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-background: var(--color-surface);
    --pagefind-ui-border: var(--color-line);
    --pagefind-ui-tag: var(--color-surface);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: var(--radius-md);
    --pagefind-ui-image-border-radius: var(--radius-sm);
    --pagefind-ui-font: var(--font-sans);
  }

  .search-filters {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    overflow-x: auto;
    padding-bottom: 0.25rem;
    scrollbar-width: none;
  }

  .search-filters::-webkit-scrollbar {
    display: none;
  }

  .search-filter-tab {
    flex-shrink: 0;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: var(--color-surface);
    color: var(--color-text-muted);
    font: inherit;
    font-size: 0.9rem;
    padding: 0.45rem 0.95rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .search-filter-tab:hover,
  .search-filter-tab.active {
    border-color: var(--color-primary);
    color: var(--color-heading);
    background: var(--color-primary-soft-bg);
  }

  .search-root :global(.pagefind-ui),
  .search-root :global(pagefind-searchbox) {
    width: 100%;
    display: block;
  }

  .search-root :global(.pagefind-ui__search-input),
  .search-root :global(.pf-searchbox-input) {
    background: var(--color-input-bg);
    color: var(--color-text);
    border-color: var(--color-line);
    font-size: 1.05rem;
    padding: 0.85rem 1rem;
  }

  .search-root :global(.pagefind-ui__result),
  .search-root :global(.pf-result-card) {
    border-color: var(--color-line);
    background: var(--gradient-glass);
  }

  .search-root :global(.pagefind-ui__result-title),
  .search-root :global(.pf-result-title) {
    color: var(--color-heading);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .search-root :global(.pagefind-ui__result-excerpt),
  .search-root :global(.pf-result-excerpt) {
    color: var(--color-text-muted);
  }

  .search-root :global(.search-type-badge) {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    background: var(--color-primary-soft-bg);
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .search-root :global(mark[data-search-highlight]) {
    background: color-mix(in srgb, var(--color-primary) 18%, transparent);
    color: inherit;
    padding: 0 0.15em;
    border-radius: 0.25em;
  }

  .search-empty {
    margin-top: var(--space-xl);
    border: var(--border-glass);
    border-radius: var(--radius-lg);
    background: var(--gradient-glass);
    padding: 1.25rem 1.25rem 0.25rem;
  }

  .search-empty__title {
    margin: 0 0 0.5rem;
    color: var(--color-heading);
  }

  .search-empty__hint {
    margin: 0 0 1rem;
    color: var(--color-text-muted);
  }

  .search-root--compact {
    max-width: 100%;
  }

  .search-root--compact .search-filters {
    margin-bottom: 0.75rem;
  }
</style>
