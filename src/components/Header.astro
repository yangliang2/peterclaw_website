---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/blog", label: "Blog" },
  { href: "/projects", label: "Projects" },
];
---

<header class="border-b border-line bg-paper/90">
  <div class="mx-auto flex max-w-5xl flex-col gap-4 px-6 py-5 sm:flex-row sm:items-center sm:justify-between">
    <a href="/" class="text-lg font-semibold tracking-normal">Peterclaw</a>
    <nav aria-label="Primary navigation" class="flex flex-wrap gap-4 text-sm text-muted">
      {navItems.map((item) => (
        <a class="transition hover:text-ink" href={item.href}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>
