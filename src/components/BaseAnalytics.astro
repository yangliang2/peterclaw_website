---
/**
 * Privacy-friendly Analytics component.
 * Supports Plausible (recommended) and Umami.
 * Only loads in production to avoid polluting development data.
 */

// Plausible Config
const plausibleDomain = import.meta.env.PLAUSIBLE_DOMAIN;
const plausibleScriptUrl = import.meta.env.PLAUSIBLE_SCRIPT_URL || 'https://plausible.io/js/script.js';

// Umami Config
const umamiWebsiteId = import.meta.env.UMAMI_WEBSITE_ID;
const umamiScriptUrl = import.meta.env.UMAMI_SCRIPT_URL || 'https://analytics.eu.umami.is/script.js';

const isProd = import.meta.env.PROD;
---

{isProd && plausibleDomain && (
  <script is:inline defer data-domain={plausibleDomain} src={plausibleScriptUrl}></script>
)}

{isProd && umamiWebsiteId && (
  <script is:inline async src={umamiScriptUrl} data-website-id={umamiWebsiteId}></script>
)}
