---
/**
 * Privacy-friendly Analytics component.
 * Supports Plausible (recommended) and Umami.
 * Only loads in production to avoid polluting development data.
 */

// Plausible Config
const plausibleDomain = import.meta.env.PLAUSIBLE_DOMAIN;
const plausibleScriptUrl = import.meta.env.PLAUSIBLE_SCRIPT_URL || 'https://plausible.io/js/script.js';

// Umami Config
const umamiWebsiteId = import.meta.env.UMAMI_WEBSITE_ID;
const umamiScriptUrl = import.meta.env.UMAMI_SCRIPT_URL || 'https://analytics.eu.umami.is/script.js';

const isProd = import.meta.env.PROD;
const isDev = import.meta.env.DEV;
const hasAnalytics = Boolean(isProd && (plausibleDomain || umamiWebsiteId));
---

{isProd && plausibleDomain && (
  <script is:inline defer data-domain={plausibleDomain} src={plausibleScriptUrl}></script>
)}

{isProd && umamiWebsiteId && (
  <script is:inline async src={umamiScriptUrl} data-website-id={umamiWebsiteId}></script>
)}

<script is:inline define:vars={{ hasAnalytics, isDev }}>
  window.trackEvent = function trackEvent(name, props = {}) {
    if (window.umami && typeof window.umami.track === 'function') {
      window.umami.track(name, props);
    }

    if (window.plausible && typeof window.plausible === 'function') {
      window.plausible(name, { props });
    }

    if (isDev) {
      console.log(`[Analytics] ${name}`, props);
    }
  };

  if (hasAnalytics || isDev) {
    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const link = target.closest('a');
      if (!link) return;

      const href = link.getAttribute('href');
      if (!href) return;

      if (href.endsWith('rss.xml')) {
        window.trackEvent('rss_click', {
          location: link.closest('footer') ? 'footer' : 'navbar',
          url: href
        });
        return;
      }

      if (href.startsWith('http') && !href.includes(window.location.hostname)) {
        window.trackEvent('external_link_click', {
          url: href,
          text: link.innerText.trim().substring(0, 100)
        });
      }
    });

    document.addEventListener('copy', () => {
      const selection = window.getSelection();
      if (!selection || selection.isCollapsed) return;

      try {
        const range = selection.getRangeAt(0);
        const container = range.commonAncestorContainer;
        const element = container.nodeType === 1 ? container : container.parentElement;
        const pre = element?.closest('pre');

        if (pre) {
          const code = pre.querySelector('code');
          const language = code
            ? Array.from(code.classList).find((className) => className.startsWith('language-'))?.replace('language-', '')
            : 'unknown';

          window.trackEvent('code_copy', {
            language
          });
        }
      } catch {
      }
    });
  }
</script>
