---
import { ui, type Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = ui[locale];
const prefix = `/${locale}`;
const navItems = [
  { name: copy.about, href: `${prefix}/about/` },
  { name: copy.now, href: `${prefix}/now/` },
  { name: copy.projects, href: `${prefix}/projects/` },
  { name: copy.blog, href: `${prefix}/blog/` },
  { name: copy.knowledge, href: `${prefix}/knowledge/` },
  { name: copy.tools, href: `${prefix}/tools/` }
];
---

<nav class="navbar" aria-label="Primary" data-pagefind-ignore="all">
  <div class="container">
    <a href={`${prefix}/`} class="logo">
      <span class="gradient-text">{copy.siteTitle}</span>
    </a>
    <ul class="nav-links">
      {navItems.map((item) => <li><a href={item.href}>{item.name}</a></li>)}
      <li>
        <a href={`${prefix}/search/`} class="search-link" aria-label={copy.search}>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          <span class="search-label">{copy.search}</span>
        </a>
      </li>
      <li>
        <button class="theme-toggle" type="button" aria-label="Toggle theme" title="Toggle theme">
          <svg
            class="theme-icon theme-icon-sun"
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="m4.93 4.93 1.41 1.41"></path>
            <path d="m17.66 17.66 1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="m6.34 17.66-1.41 1.41"></path>
            <path d="m19.07 4.93-1.41 1.41"></path>
          </svg>
          <svg
            class="theme-icon theme-icon-moon"
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 3a6 6 0 0 0 9 7.3 9 9 0 1 1-9-7.3Z"></path>
          </svg>
        </button>
      </li>
    </ul>
  </div>
</nav>

<script>
  (() => {
    const storageKey = 'peterclaw-theme';
    const toggle = document.querySelector<HTMLButtonElement>('.theme-toggle');

    function setTheme(theme: 'light' | 'dark') {
      document.documentElement.dataset.theme = theme;
      try {
        localStorage.setItem(storageKey, theme);
      } catch {
        // Keep the live theme switch working when storage is unavailable.
      }
      toggle?.setAttribute('aria-pressed', String(theme === 'dark'));
    }

    if (toggle) {
      const currentTheme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
      toggle.setAttribute('aria-pressed', String(currentTheme === 'dark'));
      toggle.addEventListener('click', () => {
        const nextTheme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        setTheme(nextTheme);
      });
    }
  })();
</script>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: var(--space-md) 0;
    background: var(--color-navbar-bg);
    border-bottom: var(--border-glass);
    backdrop-filter: blur(12px);
  }

  .navbar .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .nav-links a {
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .nav-links a:hover {
    color: var(--color-text);
  }

  .search-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .search-label {
    font-weight: 500;
  }

  .theme-toggle {
    position: relative;
    display: inline-grid;
    width: 2.25rem;
    height: 2.25rem;
    place-items: center;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--color-input-bg);
    color: var(--color-text-muted);
    cursor: pointer;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .theme-toggle:hover {
    border-color: var(--color-primary);
    color: var(--color-text);
  }

  .theme-icon {
    grid-area: 1 / 1;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  :global([data-theme='dark']) .theme-icon-sun,
  .theme-icon-moon {
    opacity: 0;
    transform: scale(0.75) rotate(-20deg);
  }

  :global([data-theme='dark']) .theme-icon-moon {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  @media (max-width: 640px) {
    .search-label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }

  @media (max-width: 640px) {
    .navbar .container {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
