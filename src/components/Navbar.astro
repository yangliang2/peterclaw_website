---
import { ui, type Locale, localePath, locales } from '@/lib/i18n';

interface Props {
  locale: Locale;
  languageSwitchPath?: string;
}

const { locale, languageSwitchPath } = Astro.props;
const copy = ui[locale];
const prefix = `/${locale}`;
const currentPath = Astro.url.pathname;
const otherLocale = locales.find((l) => l !== locale) as Locale;
const switchPath = languageSwitchPath ?? localePath(currentPath, otherLocale);
const navItems = [
  { name: copy.about, href: `${prefix}/about/` },
  { name: copy.now, href: `${prefix}/now/` },
  { name: copy.projects, href: `${prefix}/projects/` },
  { name: copy.products, href: `${prefix}/product/` },
  { name: copy.consulting, href: `${prefix}/consulting/` },
  { name: copy.blog, href: `${prefix}/blog/` },
  { name: copy.knowledge, href: `${prefix}/knowledge/` },
  { name: copy.tools, href: `${prefix}/tools/` }
];
const isCurrentPath = (href: string) => currentPath === href || currentPath.startsWith(href);
---

<nav class="navbar" aria-label={copy.primaryNavigation} data-pagefind-ignore="all">
  <div class="container">
    <div class="bar">
      <a href={`${prefix}/`} class="logo">
        <span class="gradient-text">{copy.siteTitle}</span>
      </a>

      <div class="bar-actions">
        <a
          href={switchPath}
          class="lang-switch"
          aria-label={`Switch to ${otherLocale === 'zh' ? 'Chinese' : 'English'}`}
          title={otherLocale === 'zh' ? '切换到中文' : 'Switch to English'}
        >
          {locale === 'zh' ? 'EN' : '中'}
        </a>

        <button
          class="theme-toggle"
          type="button"
          aria-label={copy.themeToggleToDark}
          title={copy.themeToggleToDark}
          data-label-light={copy.themeToggleToLight}
          data-label-dark={copy.themeToggleToDark}
          data-label-system={copy.themeToggleToSystem}
          data-mode-system={copy.themeModeSystem}
        >
          <svg
            class="theme-icon theme-icon-sun"
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="m4.93 4.93 1.41 1.41"></path>
            <path d="m17.66 17.66 1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="m6.34 17.66-1.41 1.41"></path>
            <path d="m19.07 4.93-1.41 1.41"></path>
          </svg>
          <svg
            class="theme-icon theme-icon-moon"
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 3a6 6 0 0 0 9 7.3 9 9 0 1 1-9-7.3Z"></path>
          </svg>
          <svg
            class="theme-icon theme-icon-system"
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2" y="3" width="20" height="14" rx="2"></rect>
            <path d="M8 21h8"></path>
            <path d="M12 17v4"></path>
          </svg>
        </button>

        <button
          class="menu-toggle"
          type="button"
          aria-label={copy.primaryNavigation}
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="menu-icon" aria-hidden="true"></span>
        </button>
      </div>
    </div>

    <ul class="nav-links nav-links-desktop">
      {navItems.map((item) => (
        <li>
          <a href={item.href} aria-current={isCurrentPath(item.href) ? 'page' : undefined}>
            {item.name}
          </a>
        </li>
      ))}
      <li>
        <a
          href={`${prefix}/search/`}
          class="search-link"
          aria-label={copy.search}
          aria-current={isCurrentPath(`${prefix}/search/`) ? 'page' : undefined}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          <span class="search-label">{copy.search}</span>
        </a>
      </li>
    </ul>

    <div class="menu-backdrop" data-menu-backdrop hidden></div>
    <div id="mobile-menu" class="menu-panel" data-menu-panel hidden>
      <ul class="nav-links nav-links-mobile" data-menu-links>
        {navItems.map((item) => (
          <li>
            <a href={item.href} aria-current={isCurrentPath(item.href) ? 'page' : undefined}>
              {item.name}
            </a>
          </li>
        ))}
        <li>
          <a
            href={`${prefix}/search/`}
            class="search-link"
            aria-label={copy.search}
            aria-current={isCurrentPath(`${prefix}/search/`) ? 'page' : undefined}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
            <span class="search-label">{copy.search}</span>
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<script>
  (() => {
    type ThemePreference = 'light' | 'dark' | 'system';

    const toggle = document.querySelector<HTMLButtonElement>('.theme-toggle');

    function nextLabel(preference: ThemePreference) {
      if (preference === 'light') {
        return toggle?.dataset.labelDark ?? 'Switch to dark mode';
      }
      if (preference === 'dark') {
        return toggle?.dataset.labelSystem ?? 'Switch to system theme';
      }
      return toggle?.dataset.labelLight ?? 'Switch to light mode';
    }

    function syncToggleState() {
      const preference = (document.documentElement.dataset.themePreference ??
        'system') as ThemePreference;
      const resolved = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';

      toggle?.setAttribute('aria-pressed', String(resolved === 'dark'));
      toggle?.setAttribute('data-active-preference', preference);

      const label = nextLabel(preference);
      toggle?.setAttribute('aria-label', label);
      toggle?.setAttribute('title', label);
    }

    requestAnimationFrame(() => {
      document.documentElement.classList.add('theme-transition');
    });

    syncToggleState();

    toggle?.addEventListener('click', () => {
      window.peterclawTheme?.cyclePreference();
      syncToggleState();
    });

    document.documentElement.addEventListener('peterclaw-theme-change', () => {
      syncToggleState();
    });
  })();
</script>

<script>
  (() => {
    const locale = document.documentElement.getAttribute('lang') || 'zh';
    const prefix = `/${locale}`;
    const searchPath = `${prefix}/search/`;

    function focusSearchInput() {
      const input = document.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
      input?.focus();
      input?.select();
    }

    document.addEventListener('keydown', (e) => {
      const key = e.key.toLowerCase();
      const isK = key === 'k';
      const withMod = e.metaKey || e.ctrlKey;
      if (!isK || !withMod) return;

      // Don't hijack typing in inputs/textareas/contenteditable.
      const target = e.target as HTMLElement | null;
      const tag = target?.tagName?.toLowerCase();
      const isEditable =
        tag === 'input' ||
        tag === 'textarea' ||
        (target instanceof HTMLElement && target.isContentEditable);
      if (isEditable) return;

      e.preventDefault();

      if (window.location.pathname.startsWith(searchPath)) {
        focusSearchInput();
        return;
      }

      window.location.href = `${searchPath}?focus=1`;
    });

    document.addEventListener('astro:after-swap', () => {
      if (window.location.pathname.startsWith(searchPath)) {
        const params = new URLSearchParams(window.location.search);
        if (params.get('focus') === '1') focusSearchInput();
      }
    });
  })();
</script>

<script>
  (() => {
    const root = document.documentElement;
    const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
    const panel = document.querySelector<HTMLElement>('[data-menu-panel]');
    const backdrop = document.querySelector<HTMLElement>('[data-menu-backdrop]');
    const links = document.querySelector<HTMLElement>('[data-menu-links]');

    if (!toggle || !panel || !backdrop || !links) return;

    const menuToggle = toggle;
    const menuPanel = panel;
    const menuBackdrop = backdrop;
    const menuLinks = links;

    let scrollY = 0;

    function lockScroll() {
      scrollY = window.scrollY || 0;
      root.classList.add('nav-open');
      document.body.style.position = 'fixed';
      document.body.style.top = `-${scrollY}px`;
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.width = '100%';
    }

    function unlockScroll() {
      root.classList.remove('nav-open');
      const top = document.body.style.top;
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.left = '';
      document.body.style.right = '';
      document.body.style.width = '';
      const y = top ? Math.abs(parseInt(top, 10)) : scrollY;
      window.scrollTo(0, y);
    }

    function setOpen(next: boolean) {
      menuToggle.setAttribute('aria-expanded', String(next));
      menuPanel.hidden = !next;
      menuBackdrop.hidden = !next;
      menuToggle.classList.toggle('is-open', next);
      if (next) lockScroll();
      else unlockScroll();
    }

    function isOpen() {
      return menuToggle.getAttribute('aria-expanded') === 'true';
    }

    menuToggle.addEventListener('click', () => setOpen(!isOpen()));
    menuBackdrop.addEventListener('click', () => setOpen(false));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });

    menuLinks.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;
      if (target.closest('a')) setOpen(false);
    });

    document.addEventListener('click', (e) => {
      if (!isOpen()) return;
      const target = e.target as Node | null;
      if (!target) return;
      if (menuPanel.contains(target) || menuToggle.contains(target)) return;
      setOpen(false);
    });
  })();
</script>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: var(--space-md) 0;
    background: var(--color-navbar-bg);
    border-bottom: var(--border-glass);
    backdrop-filter: blur(12px);
  }

  .navbar .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    position: relative;
  }

  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    width: 100%;
  }

  .bar-actions {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-lg);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .nav-links a {
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .nav-links a,
  .theme-toggle,
  .lang-switch,
  .menu-toggle {
    min-width: 44px;
    min-height: 44px;
  }

  .menu-toggle {
    position: relative;
    display: inline-grid;
    width: 2.75rem;
    height: 2.75rem;
    place-items: center;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--color-input-bg);
    color: var(--color-text-muted);
    cursor: pointer;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .menu-toggle:hover {
    border-color: var(--color-primary);
    color: var(--color-text);
  }

  .menu-icon {
    position: relative;
    width: 18px;
    height: 2px;
    background: currentColor;
    border-radius: 999px;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .menu-icon::before,
  .menu-icon::after {
    content: '';
    position: absolute;
    left: 0;
    width: 18px;
    height: 2px;
    background: currentColor;
    border-radius: 999px;
    transition: transform 0.2s ease, top 0.2s ease;
  }

  .menu-icon::before {
    top: -6px;
  }

  .menu-icon::after {
    top: 6px;
  }

  .menu-toggle.is-open .menu-icon {
    background: transparent;
  }

  .menu-toggle.is-open .menu-icon::before {
    top: 0;
    transform: rotate(45deg);
  }

  .menu-toggle.is-open .menu-icon::after {
    top: 0;
    transform: rotate(-45deg);
  }

  .menu-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(2px);
    z-index: 90;
  }

  .menu-panel {
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    margin: 0 auto;
    padding: var(--space-md);
    background: var(--color-navbar-bg);
    border-bottom: var(--border-glass);
    z-index: 95;
  }

  .menu-panel .nav-links {
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-sm);
  }

  .menu-panel .nav-links a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-md);
  }

  .menu-panel .nav-links a:hover {
    background: var(--color-input-bg);
  }

  :global(html.nav-open) {
    overflow: hidden;
  }

  .nav-links a:hover {
    color: var(--color-text);
  }

  .nav-links a[aria-current='page'] {
    color: var(--color-heading);
    font-weight: 700;
  }

  .search-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .search-label {
    font-weight: 500;
  }

  .lang-switch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--color-input-bg);
    color: var(--color-text-muted);
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    cursor: pointer;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .lang-switch:hover {
    border-color: var(--color-primary);
    color: var(--color-text);
  }

  .theme-toggle {
    position: relative;
    display: inline-grid;
    width: 2.25rem;
    height: 2.25rem;
    place-items: center;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--color-input-bg);
    color: var(--color-text-muted);
    cursor: pointer;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .theme-toggle:hover {
    border-color: var(--color-primary);
    color: var(--color-text);
  }

  .theme-icon {
    grid-area: 1 / 1;
    opacity: 0;
    transform: scale(0.75) rotate(-20deg);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  :global(html[data-theme-preference='light']) .theme-icon-sun,
  :global(html[data-theme-preference='dark']) .theme-icon-moon,
  :global(html[data-theme-preference='system']) .theme-icon-system {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  @media (max-width: 640px) {
    .search-label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }

  @media (max-width: 640px) {
    .nav-links-desktop {
      display: none;
    }
  }

  @media (min-width: 641px) {
    .menu-toggle,
    .menu-backdrop,
    .menu-panel {
      display: none;
    }

    .navbar .container {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-md);
    }

    .bar {
      flex: 0 0 auto;
      width: auto;
    }

    .nav-links-desktop {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--space-lg);
    }
  }
</style>
