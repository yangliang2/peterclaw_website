---
import { ui, type Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = ui[locale];
const prefix = `/${locale}`;
const navItems = [
  { name: copy.about, href: `${prefix}/about/` },
  { name: copy.now, href: `${prefix}/now/` },
  { name: copy.projects, href: `${prefix}/projects/` },
  { name: copy.blog, href: `${prefix}/blog/` },
  { name: copy.knowledge, href: `${prefix}/knowledge/` },
  { name: copy.tools, href: `${prefix}/tools/` }
];
---

<nav class="navbar" aria-label="Primary" data-pagefind-ignore="all">
  <div class="container">
    <a href={`${prefix}/`} class="logo">
      <span class="gradient-text">{copy.siteTitle}</span>
    </a>
    <ul class="nav-links">
      {navItems.map((item) => <li><a href={item.href}>{item.name}</a></li>)}
      <li>
        <a href={`${prefix}/search/`} class="search-link" aria-label={copy.search}>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          <span class="search-label">{copy.search}</span>
        </a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: var(--space-md) 0;
    background: rgba(5, 5, 5, 0.78);
    border-bottom: var(--border-glass);
    backdrop-filter: blur(12px);
  }

  .navbar .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .nav-links {
    display: flex;
    gap: var(--space-lg);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .nav-links a {
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .nav-links a:hover {
    color: var(--color-text);
  }

  .search-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .search-label {
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .search-label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }

  @media (max-width: 640px) {
    .navbar .container {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
