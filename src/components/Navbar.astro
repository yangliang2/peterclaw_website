---
import { ui, type Locale, localePath, locales } from '@/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = ui[locale];
const prefix = `/${locale}`;
const currentPath = Astro.url.pathname;
const otherLocale = locales.find((l) => l !== locale) as Locale;
const switchPath = localePath(currentPath, otherLocale);
const navItems = [
  { name: copy.about, href: `${prefix}/about/` },
  { name: copy.now, href: `${prefix}/now/` },
  { name: copy.projects, href: `${prefix}/projects/` },
  { name: copy.products, href: `${prefix}/product/` },
  { name: copy.blog, href: `${prefix}/blog/` },
  { name: copy.knowledge, href: `${prefix}/knowledge/` },
  { name: copy.tools, href: `${prefix}/tools/` }
];
---

<nav class="navbar" aria-label="Primary" data-pagefind-ignore="all">
  <div class="container">
    <a href={`${prefix}/`} class="logo">
      <span class="gradient-text">{copy.siteTitle}</span>
    </a>
    <ul class="nav-links">
      {navItems.map((item) => <li><a href={item.href}>{item.name}</a></li>)}
      <li>
        <a href={`${prefix}/search/`} class="search-link" aria-label={copy.search}>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          <span class="search-label">{copy.search}</span>
        </a>
      </li>
      <li>
        <a href={switchPath} class="lang-switch" aria-label={`Switch to ${otherLocale === 'zh' ? 'Chinese' : 'English'}`} title={otherLocale === 'zh' ? '切换到中文' : 'Switch to English'}>
          {locale === 'zh' ? 'EN' : '中'}
        </a>
      </li>
      <li>
        <button
          class="theme-toggle"
          type="button"
          aria-label={copy.themeToggleToDark}
          title={copy.themeToggleToDark}
          data-label-dark={copy.themeToggleToDark}
          data-label-light={copy.themeToggleToLight}
        >
          <svg
            class="theme-icon theme-icon-sun"
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="m4.93 4.93 1.41 1.41"></path>
            <path d="m17.66 17.66 1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="m6.34 17.66-1.41 1.41"></path>
            <path d="m19.07 4.93-1.41 1.41"></path>
          </svg>
          <svg
            class="theme-icon theme-icon-moon"
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 3a6 6 0 0 0 9 7.3 9 9 0 1 1-9-7.3Z"></path>
          </svg>
        </button>
      </li>
    </ul>
  </div>
</nav>

<script>
  (() => {
    const storageKey = 'peterclaw-theme';
    const toggle = document.querySelector<HTMLButtonElement>('.theme-toggle');

    function hasStoredPreference() {
      try {
        const stored = localStorage.getItem(storageKey);
        return stored === 'light' || stored === 'dark';
      } catch {
        return false;
      }
    }

    function syncToggleState(theme: 'light' | 'dark') {
      toggle?.setAttribute('aria-pressed', String(theme === 'dark'));
      const label =
        theme === 'dark'
          ? (toggle?.dataset.labelLight ?? 'Switch to light mode')
          : (toggle?.dataset.labelDark ?? 'Switch to dark mode');
      if (label && toggle) {
        toggle.setAttribute('aria-label', label);
        toggle.setAttribute('title', label);
      }
    }

    function applyTheme(theme: 'light' | 'dark', persist = false) {
      document.documentElement.dataset.theme = theme;
      if (persist) {
        try {
          localStorage.setItem(storageKey, theme);
        } catch {
          // Keep the live theme switch working when storage is unavailable.
        }
      }
      syncToggleState(theme);
    }

    requestAnimationFrame(() => {
      document.documentElement.classList.add('theme-transition');
    });


    if (toggle) {
      const currentTheme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
      syncToggleState(currentTheme);
      toggle.addEventListener('click', () => {
        const nextTheme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        applyTheme(nextTheme, true);
      });
    }

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (event) => {
      if (hasStoredPreference()) return;
      applyTheme(event.matches ? 'dark' : 'light');
    });
  })();
</script>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: var(--space-md) 0;
    background: var(--color-navbar-bg);
    border-bottom: var(--border-glass);
    backdrop-filter: blur(12px);
  }

  .navbar .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-lg);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .nav-links a {
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .nav-links a:hover {
    color: var(--color-text);
  }

  .search-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .search-label {
    font-weight: 500;
  }

  .lang-switch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--color-input-bg);
    color: var(--color-text-muted);
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    cursor: pointer;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .lang-switch:hover {
    border-color: var(--color-primary);
    color: var(--color-text);
  }

  .theme-toggle {
    position: relative;
    display: inline-grid;
    width: 2.25rem;
    height: 2.25rem;
    place-items: center;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--color-input-bg);
    color: var(--color-text-muted);
    cursor: pointer;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .theme-toggle:hover {
    border-color: var(--color-primary);
    color: var(--color-text);
  }

  .theme-icon {
    grid-area: 1 / 1;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  :global([data-theme='dark']) .theme-icon-sun,
  .theme-icon-moon {
    opacity: 0;
    transform: scale(0.75) rotate(-20deg);
  }

  :global([data-theme='dark']) .theme-icon-moon {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  @media (max-width: 640px) {
    .search-label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }

  @media (max-width: 640px) {
    .navbar .container {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
