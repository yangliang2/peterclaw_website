---
import { ui, type Locale } from '@/lib/i18n';
import type { TocEntry } from '@/utils/reading';

interface Props {
  locale: Locale;
  entries: TocEntry[];
}

const { locale, entries } = Astro.props;
const copy = ui[locale];

if (entries.length === 0) {
  return null;
}
---

<aside class="article-toc" data-article-toc aria-label={copy.tocTitle}>
  <button
    type="button"
    class="article-toc-toggle"
    data-toc-toggle
    aria-expanded="false"
    aria-controls="article-toc-panel"
  >
    {copy.tocToggle}
  </button>
  <nav id="article-toc-panel" class="article-toc-panel" data-toc-panel>
    <p class="article-toc-label">{copy.tocTitle}</p>
    <ol>
      {
        entries.map((entry) => (
          <li class:list={[`depth-${entry.level}`]}>
            <a href={`#${entry.id}`} data-toc-link data-toc-id={entry.id}>
              {entry.text}
            </a>
          </li>
        ))
      }
    </ol>
  </nav>
</aside>

<script>
  import { slugifyHeading } from '@/utils/reading';

  const initArticleToc = () => {
    const toc = document.querySelector('[data-article-toc]');
    const article = document.querySelector<HTMLElement>('article[data-pagefind-body]');

    if (!toc || !article) {
      return;
    }

    const toggle = toc.querySelector<HTMLButtonElement>('[data-toc-toggle]');
    const panel = toc.querySelector<HTMLElement>('[data-toc-panel]');
    const links = [...toc.querySelectorAll<HTMLAnchorElement>('[data-toc-link]')];

    if (links.length === 0) {
      return;
    }

    const expectedIds = links
      .map((link) => link.dataset.tocId ?? '')
      .filter((id): id is string => id.length > 0);
    const headings = [...article.querySelectorAll<HTMLHeadingElement>('h2, h3')];
    const slugCounts = new Map<string, number>();

    const nextId = (text: string) => {
      const base = slugifyHeading(text);
      const used = slugCounts.get(base) ?? 0;
      slugCounts.set(base, used + 1);
      return used === 0 ? base : `${base}-${used + 1}`;
    };

    headings.forEach((heading, index) => {
      const expected = expectedIds[index];
      if (expected) {
        heading.id = expected;
      } else if (!heading.id) {
        heading.id = nextId(heading.textContent ?? `section-${index + 1}`);
      }
    });

    const setActive = (id: string) => {
      for (const link of links) {
        const active = link.dataset.tocId === id;
        link.classList.toggle('is-active', active);
        if (active) {
          link.setAttribute('aria-current', 'location');
        } else {
          link.removeAttribute('aria-current');
        }
      }
    };

    const observed = headings.filter((heading) => heading.id && expectedIds.includes(heading.id));

    if (observed.length > 0 && 'IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (records) => {
          const visible = records
            .filter((record) => record.isIntersecting)
            .sort((left, right) => right.intersectionRatio - left.intersectionRatio);

          if (visible[0]?.target.id) {
            setActive(visible[0].target.id);
          }
        },
        { rootMargin: '-20% 0px -65% 0px', threshold: [0, 0.25, 0.5, 1] }
      );

      for (const heading of observed) {
        observer.observe(heading);
      }
    }

    if (toggle && panel) {
      toggle.addEventListener('click', () => {
        const open = panel.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', String(open));
      });
    }
  };

  initArticleToc();
</script>

<style>
  .article-toc-toggle {
    display: none;
    width: 100%;
    margin: 0 0 1rem;
    padding: 0.65rem 1rem;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--gradient-glass);
    color: var(--color-heading);
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    text-align: left;
  }

  .article-toc-label {
    margin: 0 0 0.75rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-toc-panel ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.45rem;
  }

  .article-toc-panel a {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.92rem;
    line-height: 1.45;
    text-decoration: none;
    border-left: 2px solid transparent;
    padding-left: 0.65rem;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .article-toc-panel a:hover,
  .article-toc-panel a.is-active {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .article-toc-panel .depth-3 a {
    padding-left: 1.25rem;
    font-size: 0.86rem;
  }

  @media (min-width: 1024px) {
    .article-toc {
      position: sticky;
      top: 5rem;
      align-self: start;
      max-height: calc(100vh - 6rem);
      overflow: auto;
      padding-left: 0.5rem;
    }

    .article-toc-toggle {
      display: none !important;
    }

    .article-toc-panel {
      display: block !important;
    }
  }

  @media (max-width: 1023px) {
    .article-toc-toggle {
      display: block;
    }

    .article-toc-panel {
      display: none;
      padding: 1rem;
      border: var(--border-glass);
      border-radius: var(--radius-md);
      background: var(--gradient-glass);
    }

    .article-toc-panel.is-open {
      display: block;
    }

    .article-toc-label {
      display: none;
    }
  }
</style>
