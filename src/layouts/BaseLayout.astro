---
import BaseAnalytics from '@/components/BaseAnalytics.astro';
import BaseHead from '@/components/BaseHead.astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import Fonts from '@/components/Fonts.astro';
import Footer from '@/components/Footer.astro';
import Navbar from '@/components/Navbar.astro';
import { ui, type Locale } from '@/lib/i18n';
import '@/styles/theme.css';
import { ClientRouter, fade } from 'astro:transitions';

const pageFade = fade({ duration: '250ms' });

interface Props {
  title?: string;
  description?: string;
  locale: Locale;
  canonicalPath?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  publishedTime?: string;
  modifiedTime?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  alternateLocales?: { locale: Locale; path: string }[];
  noindex?: boolean;
}

const {
  title,
  description,
  locale,
  canonicalPath,
  ogType,
  ogImage,
  publishedTime,
  modifiedTime,
  structuredData,
  alternateLocales,
  noindex,
} = Astro.props;
const copy = ui[locale];
const pageTitle = title ? `${title} | ${copy.siteTitle}` : copy.siteTitle;
const pageDescription = description ?? copy.tagline;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (() => {
        const storageKey = 'peterclaw-theme';
        const root = document.documentElement;
        const storedTheme = (() => {
          try {
            return localStorage.getItem(storageKey);
          } catch {
            return null;
          }
        })();
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = storedTheme === 'light' || storedTheme === 'dark'
          ? storedTheme
          : prefersDark
            ? 'dark'
            : 'light';

        root.dataset.theme = theme;
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="PeterClaw" href="/rss.xml" />
    <Fonts />
    <BaseHead
      title={pageTitle}
      description={pageDescription}
      locale={locale}
      canonicalPath={canonicalPath}
      ogType={ogType}
      ogImage={ogImage}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      structuredData={structuredData}
      alternateLocales={alternateLocales}
      noindex={noindex}
    />
    <BaseAnalytics />
    <ClientRouter />
    <SpeedInsights />
  </head>
  <body>
    <Navbar locale={locale} />
    <main transition:animate={pageFade}>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>

<style is:global>
  main {
    width: min(100%, 960px);
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }

  .hero {
    padding: 4rem 0 3rem;
    border-top: var(--border-glass);
    border-bottom: var(--border-glass);
  }

  h1 {
    max-width: 800px;
    margin: 0 0 1.5rem;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.1;
  }

  .lede {
    max-width: 680px;
    color: var(--color-text-muted);
    font-size: 1.25rem;
    line-height: 1.6;
    margin-bottom: 3rem;
  }

  .content-list {
    display: grid;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .content-item {
    display: grid;
    gap: 0.5rem;
    padding: 1.5rem;
    color: inherit;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--gradient-glass);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .content-item:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    background: var(--color-surface-hover);
  }

  .content-item h2,
  .content-item h3 {
    margin: 0;
    font-size: 1.5rem;
  }

  .content-hero-image {
    width: 100%;
    max-height: 220px;
    object-fit: cover;
    border-radius: var(--radius-md);
    margin-bottom: 0.75rem;
    border: var(--border-glass);
  }

  article > .content-hero-image {
    max-height: 280px;
    margin-bottom: 1.25rem;
  }

  .meta {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }

  /* Article Typography */
  article {
    max-width: 720px;
    margin: 0 auto;
    line-height: 1.8;
    font-size: 1.125rem;
    color: var(--color-article);
  }

  article h2 {
    font-size: 2rem;
    margin: 4rem 0 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-line);
  }

  article h3 {
    font-size: 1.5rem;
    margin: 2.5rem 0 1rem;
  }

  article p {
    margin-bottom: 1.8rem;
  }

  article ul,
  article ol {
    margin-bottom: 1.8rem;
    padding-left: 1.5rem;
  }

  article li {
    margin-bottom: 0.6rem;
  }

  article blockquote {
    margin: 2.5rem 0;
    padding: 1rem 2rem;
    border-left: 4px solid var(--color-primary);
    background: var(--color-primary-soft-bg);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    color: var(--color-text-muted);
  }

  article blockquote p {
    margin-bottom: 0;
  }

  article hr {
    margin: 4rem 0;
    border: 0;
    border-top: 1px solid var(--color-line);
  }

  article table {
    width: 100%;
    margin: 2.5rem 0;
    border-collapse: collapse;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  article th,
  article td {
    padding: 1rem;
    border-bottom: 1px solid var(--color-line);
    text-align: left;
  }

  article th {
    font-weight: 700;
    color: var(--color-heading);
    background: var(--color-soft-bg);
  }

  article img {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin: 2rem 0;
    border: var(--border-glass);
  }

  article pre {
    padding: 1.5rem;
    border-radius: var(--radius-md);
    margin: 2.5rem 0;
    border: var(--border-glass);
    background: var(--color-code-bg) !important;
    font-size: 0.95rem;
    overflow-x: auto;
  }

  article code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 0.2em 0.4em;
    background: var(--color-code-inline-bg);
    border-radius: 4px;
    color: var(--color-secondary);
  }

  article pre code {
    padding: 0;
    background: none;
    color: inherit;
  }

  article strong {
    color: var(--color-heading);
  }
</style>
