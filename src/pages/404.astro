---
import PopularArticles from '@/components/PopularArticles.astro';
import Search from '@/components/Search.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { defaultLocale, isLocale, ui, type Locale } from '@/lib/i18n';

Astro.response.status = 404;

function localeFromPath(pathname: string): Locale {
  const match = pathname.match(/^\/(zh|en)(\/|$)/);
  if (match && isLocale(match[1])) {
    return match[1];
  }
  return defaultLocale;
}

const locale = localeFromPath(Astro.url.pathname);
const copy = ui[locale];
const homePath = `/${locale}/`;
const requestedPath = Astro.url.pathname;
---

<BaseLayout
  locale={locale}
  title={copy.notFoundTitle}
  description={copy.notFoundDescription}
  canonicalPath={requestedPath}
  noindex
>
  <section class="not-found-hero" aria-labelledby="not-found-title">
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="not-found-hero-content">
      <p class="not-found-code" aria-hidden="true">{copy.notFoundCode}</p>
      <h1 id="not-found-title" class="not-found-title">{copy.notFoundTitle}</h1>
      <p class="lede not-found-lede">{copy.notFoundDescription}</p>
      <div class="not-found-actions">
        <a class="btn btn-primary" href={homePath}>{copy.notFoundHome}</a>
        <a class="btn btn-secondary" href={`/${locale}/search/`}>{copy.search}</a>
      </div>
    </div>
  </section>

  <section class="not-found-search" aria-labelledby="not-found-search-heading" data-pagefind-ignore="all">
    <h2 id="not-found-search-heading">{copy.notFoundSearchHeading}</h2>
    <p class="not-found-search-hint">{copy.searchDescription}</p>
    <Search locale={locale} />
  </section>

  <PopularArticles locale={locale} limit={4} />
</BaseLayout>

<script define:vars={{ requestedPath }}>
  function trackNotFound() {
    if (typeof window.trackEvent !== 'function') return;
    window.trackEvent('page_not_found', {
      path: requestedPath || window.location.pathname,
      referrer: document.referrer || '',
    });
  }

  trackNotFound();
  document.addEventListener('astro:after-swap', trackNotFound);
</script>

<style>
  .not-found-hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    margin-bottom: clamp(2.5rem, 6vw, 3.5rem);
    padding: clamp(3rem, 8vw, 5rem) clamp(1.25rem, 5vw, 3rem);
    border: var(--border-glass);
    border-radius: clamp(var(--radius-lg), 3vw, 1.75rem);
    background:
      radial-gradient(circle at 18% 22%, var(--color-primary-soft-bg), transparent 42%),
      var(--gradient-glass);
  }

  .not-found-hero::after {
    position: absolute;
    z-index: -1;
    right: clamp(-7rem, -8vw, -2.5rem);
    bottom: clamp(-8rem, -11vw, -3rem);
    width: clamp(14rem, 38vw, 24rem);
    aspect-ratio: 1;
    content: '';
    border-radius: 999px;
    background: var(--gradient-ai);
    filter: blur(52px);
    opacity: 0.16;
  }

  .hero-grid {
    position: absolute;
    z-index: -1;
    inset: 0;
    background-image:
      linear-gradient(var(--color-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-line) 1px, transparent 1px);
    background-size: 3.25rem 3.25rem;
    mask-image: radial-gradient(ellipse 70% 80% at 72% 48%, black, transparent);
    opacity: 0.5;
  }

  .not-found-hero-content {
    max-width: 40rem;
  }

  .not-found-code {
    margin: 0 0 0.75rem;
    font: 700 clamp(4rem, 14vw, 7rem) / 0.9 var(--font-mono);
    letter-spacing: -0.06em;
    background: var(--gradient-ai);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .not-found-title {
    margin: 0 0 1rem;
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.04em;
  }

  .not-found-lede {
    margin-bottom: clamp(1.75rem, 4vw, 2.25rem);
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    line-height: 1.7;
  }

  .not-found-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .not-found-actions .btn {
    min-width: 9rem;
    padding: 0.85rem 1.5rem;
  }

  .not-found-search {
    margin-bottom: var(--space-xl);
    max-width: 720px;
  }

  .not-found-search h2 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.35rem, 3.5vw, 1.65rem);
    letter-spacing: -0.03em;
  }

  .not-found-search-hint {
    margin: 0 0 1.25rem;
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  @media (max-width: 560px) {
    .not-found-hero {
      padding: 2.5rem 1.25rem 2.75rem;
    }

    .not-found-actions .btn {
      flex: 1 1 100%;
    }
  }
</style>
