---
import BaseLayout from "../layouts/BaseLayout.astro";

const featuredProjects = [
  {
    title: "DevSync",
    description: "一款面向开发者的实时协作工具，支持代码评审、任务追踪与团队知识库管理。",
  },
  {
    title: "AstroPress",
    description: "基于 Astro 与 Markdown 的高性能静态博客系统，探索现代前端架构的最佳实践。",
  },
  {
    title: "SaaS Dashboard",
    description: "企业级 SaaS 管理后台，集成实时数据可视化、用户权限管理与多租户架构。",
  },
];
---

<BaseLayout
  title="Peterclaw"
  description="Peterclaw 的个人网站，记录项目作品、技术思考与创作。"
>
  <section class="copy-fit mx-auto grid max-w-5xl gap-12 overflow-hidden px-6 py-16 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
    <div class="min-w-0">
      <p class="mb-4 font-mono text-sm font-medium uppercase text-accent">Personal website</p>
      <h1 class="text-5xl font-semibold leading-tight text-white sm:text-6xl">Peterclaw</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-muted [line-break:anywhere]">
        你好，我是 Peter —— 一名全栈开发者与产品设计师。我热衷于将复杂的问题转化为简洁、优雅的解决方案。在这里，你会看到我的作品、思考，以及我对技术世界的探索。
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="border border-accent bg-accent px-5 py-3 text-sm font-medium text-paper transition duration-300 hover:bg-transparent hover:text-accent" href="/projects">
          查看作品
        </a>
        <a class="border border-line px-5 py-3 text-sm font-medium text-muted transition duration-300 hover:border-accent hover:text-accent" href="/blog">
          阅读博客
        </a>
      </div>
    </div>
    <div class="min-w-0 overflow-hidden border border-line bg-surface/70 p-6 shadow-2xl shadow-cyan-950/30 sm:aspect-[4/3]" aria-hidden="true">
      <div class="h-full border border-accent/30 bg-[linear-gradient(135deg,rgba(34,211,238,0.18)_0%,rgba(15,23,42,0.95)_44%,rgba(99,102,241,0.2)_100%)] p-5">
        <div class="font-mono text-sm text-accent">~/peterclaw</div>
        <div class="mt-8 space-y-3 font-mono text-sm text-muted">
          <p><span class="text-white">status</span>: shipping notes</p>
          <p><span class="text-white">stack</span>: astro / tailwind / ts</p>
          <p><span class="text-white">focus</span>: tools, writing, systems</p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-line">
    <div class="mx-auto grid max-w-5xl gap-6 px-6 py-12 sm:grid-cols-3">
      {featuredProjects.map((project) => (
        <article class="border border-line bg-surface/60 p-5 transition duration-300 hover:border-accent/70">
          <h2 class="text-base font-semibold text-white">{project.title}</h2>
          <p class="mt-2 text-sm leading-6 text-muted">{project.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
