---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Peterclaw"
  description="Personal website for Peterclaw's writing, projects, and notes."
>
  <section class="mx-auto grid max-w-5xl gap-12 px-6 py-16 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
    <div>
      <p class="mb-4 text-sm font-medium uppercase text-accent">Personal website</p>
      <h1 class="text-5xl font-semibold leading-tight sm:text-6xl">Peterclaw</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-muted">
        A focused home for personal writing, project notes, and selected work.
        Final copy and visual direction will be integrated in the next iteration.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="border border-ink px-5 py-3 text-sm font-medium transition hover:bg-ink hover:text-paper" href="/projects">
          View projects
        </a>
        <a class="border border-line px-5 py-3 text-sm font-medium text-muted transition hover:border-ink hover:text-ink" href="/blog">
          Read blog
        </a>
      </div>
    </div>
    <div class="aspect-[4/3] border border-line bg-[linear-gradient(135deg,#f7f6f2_0%,#e7e2d7_48%,#0f766e_49%,#0f766e_52%,#f7f6f2_53%)]" aria-hidden="true"></div>
  </section>

  <section class="border-t border-line">
    <div class="mx-auto grid max-w-5xl gap-6 px-6 py-12 sm:grid-cols-3">
      <div>
        <h2 class="text-base font-semibold">Writing</h2>
        <p class="mt-2 text-sm leading-6 text-muted">Essays, technical notes, and longer-form thinking.</p>
      </div>
      <div>
        <h2 class="text-base font-semibold">Projects</h2>
        <p class="mt-2 text-sm leading-6 text-muted">A curated index of work and experiments.</p>
      </div>
      <div>
        <h2 class="text-base font-semibold">About</h2>
        <p class="mt-2 text-sm leading-6 text-muted">Background, interests, and contact details.</p>
      </div>
    </div>
  </section>
</BaseLayout>
