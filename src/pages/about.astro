---
import ContentLayout from "../layouts/ContentLayout.astro";
---

<ContentLayout title="About" description="A concise profile page for Peterclaw.">
  <div class="max-w-3xl space-y-5 text-base leading-8 text-muted">
    <p>
      This page is prepared for the final biography, interests, contact details,
      and professional background.
    </p>
    <p>
      The structure is intentionally simple so the content draft can be merged
      without redesigning the page.
    </p>
  </div>
</ContentLayout>
