---
import { getCollection } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<ContentLayout title="Blog" description="Notes, essays, and project updates.">
  {posts.length > 0 ? (
    <div class="grid gap-4">
      {posts.map((post) => (
        <article class="border border-line bg-white/45 p-5">
          <p class="text-sm text-muted">{post.data.pubDate.toLocaleDateString("en")}</p>
          <h2 class="mt-2 text-xl font-semibold">{post.data.title}</h2>
          <p class="mt-2 text-sm leading-6 text-muted">{post.data.description}</p>
        </article>
      ))}
    </div>
  ) : (
    <p class="max-w-2xl text-base leading-8 text-muted">
      Blog content will be added after the first draft is ready.
    </p>
  )}
</ContentLayout>
