---
import { getCollection } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<ContentLayout title="Blog" description="技术笔记、文章与项目更新。">
  {posts.length > 0 ? (
    <div class="grid gap-4">
      {posts.map((post) => (
        <article class="border border-line bg-surface/60 p-5 transition duration-300 hover:border-accent/70">
          <p class="font-mono text-sm text-accent">{post.data.pubDate.toLocaleDateString("zh-CN")}</p>
          <h2 class="mt-2 text-xl font-semibold text-white">
            <a class="transition hover:text-accent" href={`/blog/${post.slug}/`}>{post.data.title}</a>
          </h2>
          <p class="mt-2 text-sm leading-6 text-muted">{post.data.description}</p>
        </article>
      ))}
    </div>
  ) : (
    <p class="max-w-2xl text-base leading-8 text-muted">
      Blog content will be added after the first draft is ready.
    </p>
  )}
</ContentLayout>
