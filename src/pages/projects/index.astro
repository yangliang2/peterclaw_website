---
import { getCollection } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";

const projects = (await getCollection("projects")).filter((project) => !project.data.draft);
---

<ContentLayout title="Projects" description="项目作品、实验产品与案例记录。">
  {projects.length > 0 ? (
    <div class="grid w-full max-w-[calc(100vw-3rem)] min-w-0 gap-4 sm:max-w-none sm:grid-cols-2">
      {projects.map((project) => (
        <article class="w-full min-w-0 overflow-hidden border border-line bg-surface/60 p-5 transition duration-300 hover:border-accent/70">
          <h2 class="text-xl font-semibold text-white [line-break:anywhere]">
            {project.data.href ? (
              <a class="transition hover:text-accent" href={project.data.href} target="_blank" rel="noreferrer">
                {project.data.title}
              </a>
            ) : (
              project.data.title
            )}
          </h2>
          <p class="mt-2 text-sm leading-6 text-muted [line-break:anywhere]">{project.data.description}</p>
          {project.data.tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {project.data.tags.map((tag) => (
                <span class="max-w-full border border-accent-soft bg-accent-soft/20 px-2 py-1 font-mono text-xs text-accent [line-break:anywhere]">{tag}</span>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>
  ) : (
    <p class="max-w-2xl text-base leading-8 text-muted">
      Project entries will be added as the portfolio content is finalized.
    </p>
  )}
</ContentLayout>
