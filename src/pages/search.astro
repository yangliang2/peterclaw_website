---
import BlogChat from '@/components/BlogChat.astro';
import Search from '@/components/Search.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { defaultLocale, ui } from '@/lib/i18n';

const lang = defaultLocale;
const copy = ui[lang];
---

<BaseLayout
  locale={lang}
  title={copy.searchTitle}
  description={copy.searchDescription}
  canonicalPath="/search/"
>
  <section class="hero">
    <h1>{copy.searchTitle}</h1>
    <p class="lede">{copy.searchDescription}</p>
  </section>

  <section class="blog-chat-section" data-pagefind-ignore="all">
    <BlogChat locale={lang} />
  </section>

  <section class="search-section" data-pagefind-ignore="all">
    <Search locale={lang} />
  </section>
</BaseLayout>

<style>
  .blog-chat-section,
  .search-section {
    margin-top: var(--space-lg);
    max-width: 720px;
  }
</style>
