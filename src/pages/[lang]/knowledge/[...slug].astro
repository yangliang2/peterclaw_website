---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  buildContentAlternateLocales,
  collectionPath,
  isLocale,
  localeFromId,
  stripLocaleFromId
} from '@/lib/i18n';
import { buildArticleSchema } from '@/utils/seo';
import ArticleReader from '@/components/ArticleReader.astro';
import { estimateReadingMinutes } from '@/utils/reading';

export async function getStaticPaths() {
  const articles = await getCollection('knowledge', ({ data }) => !data.draft);
  const articleIds = articles.map((entry) => entry.id);

  return articles.map((article) => {
    const lang = localeFromId(article.id);

    return {
      params: {
        lang,
        slug: stripLocaleFromId(article.id, lang)
      },
      props: {
        article,
        alternateLocales: buildContentAlternateLocales('knowledge', article.id, articleIds)
      }
    };
  });
}

const { article, alternateLocales } = Astro.props;
const { lang } = Astro.params;
if (!isLocale(lang)) {
  return Astro.redirect('/zh/knowledge/');
}

const { Content, headings } = await render(article);
const canonicalPath = collectionPath(lang, 'knowledge', article.id);
const publishedTime = article.data.publishedAt.toISOString();
const modifiedTime = (article.data.updatedAt ?? article.data.publishedAt).toISOString();
const ogImage = article.data.ogImage;
const readingMinutes = estimateReadingMinutes(article.body);
---

<BaseLayout
  locale={lang}
  title={article.data.title}
  description={article.data.description}
  canonicalPath={canonicalPath}
  ogType="article"
  ogImage={ogImage}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  structuredData={buildArticleSchema({
    title: article.data.title,
    description: article.data.description,
    path: canonicalPath,
    locale: lang,
    publishedTime: article.data.publishedAt,
    modifiedTime: article.data.updatedAt,
    imagePath: ogImage,
  })}
  alternateLocales={alternateLocales}
>
  <ArticleReader
    title={article.data.title}
    description={article.data.description}
    metaItems={[article.data.area]}
    readingMinutes={readingMinutes}
    headings={headings}
  >
    <Content />
  </ArticleReader>
</BaseLayout>
