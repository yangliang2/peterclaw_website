---
import { getCollection, render } from 'astro:content';
import ArticleChat from '@/components/ArticleChat.astro';
import SocialShare from '@/components/SocialShare.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleFooter from '@/components/ArticleFooter.astro';
import EmailSignup from '@/components/EmailSignup.astro';
import {
  buildContentAlternateLocales,
  collectionPath,
  isLocale,
  localeFromId,
  stripLocaleFromId,
  ui,
} from '@/lib/i18n';
import {
  buildArticleSchema,
  buildBreadcrumbSchema,
  buildDynamicOgImagePath,
  buildFaqSchema,
  buildHowToSchema,
} from '@/utils/seo';
import {
  estimateReadingMinutes,
  extractTocFromMarkdown,
  formatReadingTime,
} from '@/utils/reading';
import ReadingProgress from '@/components/ReadingProgress.astro';
import ArticleToc from '@/components/ArticleToc.astro';
import PagefindMeta from '@/components/PagefindMeta.astro';
import { siteConfig } from '@/config/site';

export async function getStaticPaths() {
  const articles = await getCollection('knowledge', ({ data }) => !data.draft);
  const articleIds = articles.map((entry) => entry.id);

  return articles.map((article) => {
    const lang = localeFromId(article.id);

    const relatedPosts = articles
      .filter((candidate) => candidate.id !== article.id && localeFromId(candidate.id) === lang)
      .map((candidate) => ({
        candidate,
        score:
          (candidate.data.area === article.data.area ? 5 : 0) +
          candidate.data.tags.filter((tag) => article.data.tags.includes(tag)).length,
      }))
      .filter(({ score }) => score > 0)
      .sort(({ candidate: left, score: leftScore }, { candidate: right, score: rightScore }) =>
        rightScore - leftScore || right.data.publishedAt.valueOf() - left.data.publishedAt.valueOf()
      )
      .slice(0, 5)
      .map(({ candidate }) => candidate);

    return {
      params: {
        lang,
        slug: stripLocaleFromId(article.id, lang)
      },
      props: {
        article,
        relatedPosts,
        alternateLocales: buildContentAlternateLocales('knowledge', article.id, articleIds)
      }
    };
  });
}

const { article, relatedPosts, alternateLocales } = Astro.props;
const { lang } = Astro.params;
if (!isLocale(lang)) {
  return Astro.redirect('/zh/knowledge/');
}

const { Content } = await render(article);
const canonicalPath = collectionPath(lang, 'knowledge', article.id);
const publishedTime = article.data.publishedAt.toISOString();
const modifiedTime = (article.data.updatedAt ?? article.data.publishedAt).toISOString();
const customOgImage =
  article.data.ogImage && article.data.ogImage !== siteConfig.defaultOgImage
    ? article.data.ogImage
    : undefined;
const ogImage =
  customOgImage ??
  buildDynamicOgImagePath({
    title: article.data.title,
    description: article.data.description,
    section: 'knowledge',
    locale: lang,
    category: article.data.area,
  });
const copy = ui[lang];
const readingMinutes = estimateReadingMinutes(article.body ?? '');
const readingTimeLabel = formatReadingTime(readingMinutes, lang);
const tocEntries = extractTocFromMarkdown(article.body ?? '');
const languageSwitchPath =
  alternateLocales.find(({ locale }) => locale !== lang)?.path ?? `/${lang === 'zh' ? 'en' : 'zh'}/knowledge/`;
const structuredData = [
  buildArticleSchema({
    title: article.data.title,
    description: article.data.description,
    path: canonicalPath,
    locale: lang,
    publishedTime: article.data.publishedAt,
    modifiedTime: article.data.updatedAt,
    imagePath: ogImage,
    articleType: 'Article',
  }),
  buildBreadcrumbSchema([
    { name: copy.siteTitle, path: `/${lang}/` },
    { name: copy.knowledge, path: `/${lang}/knowledge/` },
    { name: article.data.title, path: canonicalPath },
  ]),
  ...(article.data.faq && article.data.faq.length > 0 ? [buildFaqSchema(article.data.faq)] : []),
  ...(article.data.howTo && article.data.howTo.length > 0
    ? [buildHowToSchema({ name: article.data.title, description: article.data.description, steps: article.data.howTo, imagePath: ogImage, locale: lang })]
    : []),
];
---

<BaseLayout
  locale={lang}
  title={article.data.title}
  description={article.data.description}
  canonicalPath={canonicalPath}
  ogType="article"
  ogImage={ogImage}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  structuredData={structuredData}
  alternateLocales={alternateLocales}
  languageSwitchPath={languageSwitchPath}
>
  <ReadingProgress />
  <div class="article-layout">
    <ArticleToc locale={lang} entries={tocEntries} />
    <article class="article-main" data-pagefind-body>
      <PagefindMeta locale={lang} section="knowledge" tags={article.data.tags} />
      <p class="meta">{article.data.area}</p>
      <h1>{article.data.title}</h1>
      <p class="reading-time">{readingTimeLabel}</p>
      <p class="lede">{article.data.description}</p>
      {
        article.data.tags.length > 0 && (
          <div class="tag-list">
            {article.data.tags.map((tag) => (
              <a class="tag-link" href={`/${lang}/tags/${encodeURIComponent(tag)}/`}>
                {tag}
              </a>
            ))}
          </div>
        )
      }
      <Content />
      {
        article.data.howTo && article.data.howTo.length > 0 && (
          <section class="how-to" aria-labelledby="how-to-title">
            <h2 id="how-to-title">{lang === 'zh' ? '操作步骤' : 'How to'}</h2>
            <ol>
              {article.data.howTo.map((step) => (
                <li>
                  <h3>{step.name}</h3>
                  <p>{step.text}</p>
                  {step.url && (
                    <a href={step.url} target="_blank" rel="noopener noreferrer" class="step-link">
                      {lang === 'zh' ? '查看更多' : 'Learn more'}
                    </a>
                  )}
                </li>
              ))}
            </ol>
          </section>
        )
      }
      {
        article.data.faq && article.data.faq.length > 0 && (
          <section class="faq" aria-labelledby="faq-title">
            <h2 id="faq-title">{lang === 'zh' ? '常见问题' : 'Frequently asked questions'}</h2>
            <dl>
              {article.data.faq.map((item) => (
                <div>
                  <dt>{item.question}</dt>
                  <dd>{item.answer}</dd>
                </div>
              ))}
            </dl>
          </section>
        )
      }
      <RelatedPosts locale={lang} posts={relatedPosts} collection="knowledge" />
      <SocialShare title={article.data.title} url={Astro.url.href} />
      <ArticleFooter locale={lang} />
    </article>
  </div>
  <ArticleChat locale={lang} articleContent={article.body ?? ''} />
  <EmailSignup locale={lang} />
</BaseLayout>

<style>
  .article-layout {
    display: grid;
    gap: 2rem;
    width: min(100%, 1100px);
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .article-layout {
      grid-template-columns: minmax(0, 720px) minmax(180px, 240px);
      justify-content: center;
      align-items: start;
    }

    .article-layout .article-main {
      grid-column: 1;
      grid-row: 1;
    }

    .article-layout .article-toc {
      grid-column: 2;
      grid-row: 1;
    }
  }

  .reading-time {
    margin: -0.75rem 0 1.25rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .faq dl {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .faq dl div {
    padding: 1.1rem 1.25rem;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--gradient-glass);
  }

  .faq dt {
    margin-bottom: 0.55rem;
    color: var(--color-heading);
    font-weight: 700;
  }

  .faq dd {
    color: var(--color-article);
    line-height: 1.7;
    margin: 0;
  }

  .how-to ol {
    display: grid;
    gap: 2rem;
    padding-left: 0;
    list-style: none;
    counter-reset: step;
    margin-top: 1.5rem;
  }

  .how-to li {
    position: relative;
    padding: 1.5rem;
    padding-left: 4rem;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--gradient-glass);
    margin: 0;
  }

  .how-to li::before {
    counter-increment: step;
    content: counter(step);
    position: absolute;
    left: 1.25rem;
    top: 1.5rem;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: white;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .how-to h3 {
    margin: 0 0 0.75rem;
    font-size: 1.25rem;
  }

  .how-to p {
    margin: 0;
    color: var(--color-article);
  }

  .step-link {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--color-primary);
    text-decoration: none;
  }

  .step-link:hover {
    text-decoration: underline;
  }
</style>
