---
import { getCollection, render } from 'astro:content';
import ArticleChat from '@/components/ArticleChat.astro';
import SocialShare from '@/components/SocialShare.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleFooter from '@/components/ArticleFooter.astro';
import {
  buildContentAlternateLocales,
  collectionPath,
  isLocale,
  localeFromId,
  stripLocaleFromId,
  ui,
} from '@/lib/i18n';
import { buildArticleSchema, buildBreadcrumbSchema } from '@/utils/seo';
import {
  estimateReadingMinutes,
  extractTocFromMarkdown,
  formatReadingTime,
} from '@/utils/reading';
import ReadingProgress from '@/components/ReadingProgress.astro';
import ArticleToc from '@/components/ArticleToc.astro';
import PagefindMeta from '@/components/PagefindMeta.astro';

export async function getStaticPaths() {
  const articles = await getCollection('knowledge', ({ data }) => !data.draft);
  const articleIds = articles.map((entry) => entry.id);
  const blogPosts = await getCollection('blog', ({ data }) => !data.draft);

  return articles.map((article) => {
    const lang = localeFromId(article.id);

    const relatedPosts = blogPosts
      .filter((candidate) => localeFromId(candidate.id) === lang)
      .map((candidate) => ({
        candidate,
        score: candidate.data.tags.filter((tag) => article.data.tags.includes(tag)).length,
      }))
      .filter(({ score }) => score > 0)
      .sort(({ candidate: left, score: leftScore }, { candidate: right, score: rightScore }) =>
        rightScore - leftScore || right.data.publishedAt.valueOf() - left.data.publishedAt.valueOf()
      )
      .slice(0, 3)
      .map(({ candidate }) => candidate);

    return {
      params: {
        lang,
        slug: stripLocaleFromId(article.id, lang)
      },
      props: {
        article,
        relatedPosts,
        alternateLocales: buildContentAlternateLocales('knowledge', article.id, articleIds)
      }
    };
  });
}

const { article, relatedPosts, alternateLocales } = Astro.props;
const { lang } = Astro.params;
if (!isLocale(lang)) {
  return Astro.redirect('/zh/knowledge/');
}

const { Content } = await render(article);
const canonicalPath = collectionPath(lang, 'knowledge', article.id);
const publishedTime = article.data.publishedAt.toISOString();
const modifiedTime = (article.data.updatedAt ?? article.data.publishedAt).toISOString();
const ogImage = article.data.ogImage;
const copy = ui[lang];
const readingMinutes = estimateReadingMinutes(article.body ?? '');
const readingTimeLabel = formatReadingTime(readingMinutes, lang);
const tocEntries = extractTocFromMarkdown(article.body ?? '');
const structuredData = [
  buildArticleSchema({
    title: article.data.title,
    description: article.data.description,
    path: canonicalPath,
    locale: lang,
    publishedTime: article.data.publishedAt,
    modifiedTime: article.data.updatedAt,
    imagePath: ogImage,
    articleType: 'Article',
  }),
  buildBreadcrumbSchema([
    { name: copy.siteTitle, path: `/${lang}/` },
    { name: copy.knowledge, path: `/${lang}/knowledge/` },
    { name: article.data.title, path: canonicalPath },
  ]),
];
---

<BaseLayout
  locale={lang}
  title={article.data.title}
  description={article.data.description}
  canonicalPath={canonicalPath}
  ogType="article"
  ogImage={ogImage}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  structuredData={structuredData}
  alternateLocales={alternateLocales}
>
  <ReadingProgress />
  <div class="article-layout">
    <ArticleToc locale={lang} entries={tocEntries} />
    <article class="article-main" data-pagefind-body>
      <PagefindMeta locale={lang} section="knowledge" />
      <p class="meta">{article.data.area}</p>
      <h1>{article.data.title}</h1>
      <p class="reading-time">{readingTimeLabel}</p>
      <p class="lede">{article.data.description}</p>
      <Content />
      <RelatedPosts locale={lang} posts={relatedPosts} />
      <SocialShare title={article.data.title} url={Astro.url.href} />
      <ArticleFooter locale={lang} />
    </article>
  </div>
  <ArticleChat locale={lang} articleContent={article.body ?? ''} />
</BaseLayout>

<style>
  .article-layout {
    display: grid;
    gap: 2rem;
    width: min(100%, 1100px);
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .article-layout {
      grid-template-columns: minmax(0, 720px) minmax(180px, 240px);
      justify-content: center;
      align-items: start;
    }

    .article-layout .article-main {
      grid-column: 1;
      grid-row: 1;
    }

    .article-layout .article-toc {
      grid-column: 2;
      grid-row: 1;
    }
  }

  .reading-time {
    margin: -0.75rem 0 1.25rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
</style>
