---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { collectionPath, isLocale, localeFromId, ui } from '@/lib/i18n';
import { buildBreadcrumbSchema } from '@/utils/seo';

export function getStaticPaths() {
  return ['zh', 'en'].map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang)) {
  return Astro.redirect('/zh/knowledge/');
}

const copy = ui[lang];
const articles = (
  await getCollection('knowledge', (entry) => localeFromId(entry.id) === lang && !entry.data.draft)
).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<BaseLayout
  locale={lang}
  title={copy.knowledge}
  canonicalPath={`/${lang}/knowledge/`}
  structuredData={buildBreadcrumbSchema([
    { name: copy.siteTitle, path: `/${lang}/` },
    { name: copy.knowledge, path: `/${lang}/knowledge/` },
  ])}
>
  <h1>{copy.knowledge}</h1>
  <div class="content-list">
    {
      articles.map((article) => (
        <a class="content-item" href={collectionPath(lang, 'knowledge', article.id)}>
          <span class="meta">{article.data.area}</span>
          <h2>{article.data.title}</h2>
          <p>{article.data.description}</p>
        </a>
      ))
    }
  </div>
</BaseLayout>
