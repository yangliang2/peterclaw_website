---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { collectionPath, isLocale, localeFromId, ui, type Locale } from '@/lib/i18n';

export async function getStaticPaths() {
  const allEntries = [
    ...(await getCollection('blog', ({ data }) => !data.draft)),
    ...(await getCollection('knowledge', ({ data }) => !data.draft))
  ];

  const langTagSet = new Map<string, Set<string>>();

  for (const entry of allEntries) {
    const lang = localeFromId(entry.id);
    if (!langTagSet.has(lang)) {
      langTagSet.set(lang, new Set());
    }
    for (const tag of entry.data.tags) {
      langTagSet.get(lang)!.add(tag);
    }
  }

  const paths: { params: { lang: string; tag: string }; props: { tag: string; hasAltLang: boolean } }[] = [];

  for (const [lang, tags] of langTagSet) {
    const altLang = lang === 'zh' ? 'en' : 'zh';
    for (const tag of tags) {
      paths.push({
        params: { lang, tag },
        props: { tag, hasAltLang: langTagSet.get(altLang)?.has(tag) ?? false }
      });
    }
  }

  return paths;
}

const { lang } = Astro.params;
const { tag, hasAltLang } = Astro.props;

if (!isLocale(lang)) {
  return Astro.redirect(`/zh/tags/${encodeURIComponent(tag)}/`);
}

const copy = ui[lang];

const blogPosts = await getCollection('blog', (entry) => localeFromId(entry.id) === lang && !entry.data.draft && entry.data.tags.includes(tag));
const knowledgeArticles = await getCollection('knowledge', (entry) => localeFromId(entry.id) === lang && !entry.data.draft && entry.data.tags.includes(tag));

const allPosts = [...blogPosts, ...knowledgeArticles].sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const pageTitle = `${tag} | ${copy.tagPageTitle}`;
const tagPath = (l: Locale) => `/${l}/tags/${encodeURIComponent(tag)}/`;
const altLang = (lang === 'zh' ? 'en' : 'zh') as Locale;
const alternateLocales = [
  { locale: lang as Locale, path: tagPath(lang as Locale) },
  ...(hasAltLang ? [{ locale: altLang, path: tagPath(altLang) }] : []),
];
---

<BaseLayout locale={lang} title={pageTitle} canonicalPath={tagPath(lang as Locale)} alternateLocales={alternateLocales}>
  <p class="meta"><a href={`/${lang}/tags/`}>{copy.tagPageTitle}</a> / {tag}</p>
  <h1>{tag}</h1>

  {
    allPosts.length === 0 ? (
      <p class="meta">{copy.tagNoPosts}</p>
    ) : (
      <div class="content-list">
        {
          allPosts.map((post) => {
            const collection = post.collection === 'blog' ? 'blog' : 'knowledge';
            return (
              <a class="content-item" href={collectionPath(lang, collection, post.id)}>
                <span class="meta">
                  {post.data.publishedAt.toISOString().slice(0, 10)} · {collection === 'blog' ? copy.blog : copy.knowledge}
                </span>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
              </a>
            );
          })
        }
      </div>
    )
  }
</BaseLayout>
