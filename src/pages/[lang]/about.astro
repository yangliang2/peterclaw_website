---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ReaderFeedback from '@/components/ReaderFeedback.astro';
import SquadMemberCard from '@/components/SquadMemberCard.astro';
import { aboutCopy } from '@/config/about';
import { buildHreflangAlternates, isLocale, ui } from '@/lib/i18n';
import { buildBreadcrumbSchema, buildPersonSchema } from '@/utils/seo';

export function getStaticPaths() {
  return ['zh', 'en'].map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang)) {
  return Astro.redirect('/zh/about/');
}

const copy = aboutCopy[lang];
const siteCopy = ui[lang];
const prefix = `/${lang}`;
---

<BaseLayout
  locale={lang}
  title={copy.pageTitle}
  description={copy.metaDescription}
  canonicalPath={`${prefix}/about/`}
  alternateLocales={buildHreflangAlternates('/about/')}
  structuredData={[
    buildPersonSchema(),
    buildBreadcrumbSchema([
      { name: siteCopy.siteTitle, path: `${prefix}/` },
      { name: siteCopy.about, path: `${prefix}/about/` },
    ]),
  ]}
>
  <section class="hero about-hero">
    <p class="badge">{copy.heroBadge}</p>
    <h1 class="gradient-text">{copy.heroTitle}</h1>
    <p class="lede">{copy.heroLede}</p>
    <div class="stats" aria-label={lang === 'zh' ? '团队概览' : 'Squad overview'}>
      {copy.heroStats.map((stat) => (
        <div class="stat">
          <strong>{stat.value}</strong>
          <span>{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="about-section story">
    <h2>{copy.introHeading}</h2>
    <div class="story-copy">
      {copy.introParagraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>

  <section class="about-section squad">
    <div class="section-heading">
      <h2>{copy.squadHeading}</h2>
      <p>{copy.squadLede}</p>
    </div>
    <div class="squad-grid">
      {
        copy.members.map((member, position) => <SquadMemberCard member={member} position={position} />)
      }
    </div>
  </section>

  <section class="about-section workflow glass-card">
    <h2>{copy.workflowHeading}</h2>
    <ol>
      {copy.workflowSteps.map((step) => <li>{step}</li>)}
    </ol>
  </section>

  <section class="about-section mission">
    <div class="section-heading">
      <h2>{copy.missionHeading}</h2>
      <p>{copy.missionLede}</p>
    </div>
    <div class="mission-grid">
      {copy.missionPoints.map((point) => (
        <div class="mission-item">
          <h3>{point.title}</h3>
          <p>{point.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="closing-grid">
    <div class="experiment glass-card">
      <h2>{copy.experimentHeading}</h2>
      <p>{copy.experimentParagraph}</p>
      <a class="btn btn-primary" href={copy.diaryHref}>
        {copy.diaryCta}
      </a>
    </div>
    <div class="contact">
      <h2>{copy.contactHeading}</h2>
      <p>{copy.contactParagraph}</p>
      <nav class="contact-links" aria-label={copy.contactHeading}>
        {copy.contactLinks.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {link.label}<span aria-hidden="true"> ↗</span>
          </a>
        ))}
      </nav>
    </div>
  </section>

  <ReaderFeedback locale={lang} source={`${prefix}/about/`} />
</BaseLayout>

<style>
  .about-hero {
    padding-bottom: clamp(2.5rem, 7vw, 4rem);
  }

  .badge {
    width: max-content;
    margin-bottom: var(--space-lg);
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: var(--color-primary-soft-bg);
    color: var(--color-primary);
    font: 0.72rem/1.3 var(--font-mono);
    letter-spacing: 0.09em;
  }

  .about-hero h1 {
    max-width: none;
  }

  .about-hero .lede {
    max-width: 760px;
    margin-bottom: clamp(2rem, 5vw, 3rem);
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    max-width: 580px;
    gap: var(--space-md);
  }

  .stat {
    display: grid;
    gap: var(--space-xs);
    padding-left: var(--space-md);
    border-left: 2px solid var(--color-line);
  }

  .stat strong {
    color: var(--color-heading);
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    line-height: 1;
  }

  .stat span {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .about-section {
    margin-top: clamp(3.5rem, 8vw, 5.5rem);
  }

  .about-section h2 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    margin-bottom: var(--space-md);
  }

  .about-section p {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    line-height: 1.8;
  }

  .story {
    display: grid;
    gap: var(--space-lg);
  }

  .story-copy {
    max-width: 720px;
  }

  .section-heading {
    max-width: 720px;
    margin-bottom: var(--space-lg);
  }

  .section-heading p {
    margin-bottom: 0;
  }

  .squad-grid {
    display: grid;
    gap: var(--space-md);
  }

  @media (min-width: 640px) {
    .squad-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 900px) {
    .squad-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .workflow {
    padding: clamp(1.5rem, 5vw, 2.5rem);
  }

  .workflow ol {
    list-style: none;
    counter-reset: workflow;
    display: grid;
    gap: var(--space-lg);
    margin: var(--space-lg) 0 0;
  }

  .workflow li {
    position: relative;
    padding-left: 3rem;
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.65;
    counter-increment: workflow;
  }

  .workflow li::before {
    content: '0' counter(workflow);
    position: absolute;
    left: 0;
    top: 0.15rem;
    color: var(--color-primary);
    font: 0.85rem/1.5 var(--font-mono);
  }

  .mission-grid {
    display: grid;
    gap: var(--space-md);
  }

  .mission-item {
    padding: var(--space-lg);
    border-top: 2px solid var(--color-line);
  }

  .mission-item h3 {
    margin-bottom: var(--space-md);
    font-size: 1.2rem;
  }

  .mission-item p {
    margin-bottom: 0;
    font-size: 1rem;
    line-height: 1.65;
  }

  .closing-grid {
    display: grid;
    gap: var(--space-lg);
    margin-top: clamp(3.5rem, 8vw, 5.5rem);
  }

  .experiment {
    padding: clamp(1.5rem, 5vw, 2.5rem);
  }

  .closing-grid h2 {
    margin-bottom: var(--space-md);
    font-size: clamp(1.6rem, 4vw, 2rem);
  }

  .closing-grid p {
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  .experiment .btn {
    margin-top: var(--space-md);
  }

  .contact {
    padding: clamp(1.5rem, 5vw, 2.5rem);
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .contact-links a {
    font-weight: 600;
  }

  @media (min-width: 720px) {
    .story {
      grid-template-columns: minmax(190px, 0.65fr) 1.35fr;
      align-items: start;
    }

    .workflow ol,
    .mission-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .closing-grid {
      grid-template-columns: 1.2fr 0.8fr;
      align-items: start;
    }
  }

  @media (max-width: 500px) {
    .stats {
      grid-template-columns: 1fr;
    }
  }
</style>
