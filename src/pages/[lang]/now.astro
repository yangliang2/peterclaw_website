---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { nowCopy } from '@/config/now';
import { getRecentCommits, githubProfile } from '@/lib/github';
import { getNowToolStack } from '@/lib/now-dynamic';
import { buildHreflangAlternates, isLocale } from '@/lib/i18n';

export const prerender = false;

export function getStaticPaths() {
  return ['zh', 'en'].map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang)) {
  return Astro.redirect('/zh/now/');
}

const copy = nowCopy[lang];
const prefix = `/${lang}`;

const [{ commits, fromCache }, toolStack] = await Promise.all([
  getRecentCommits(),
  Promise.resolve(getNowToolStack(lang)),
]);

const updatedAt = new Date().toLocaleDateString(
  lang === 'zh' ? 'zh-CN' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
);

function formatCommitDate(iso: string) {
  return new Date(iso).toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
}

Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=900, stale-while-revalidate=3600'
);
---

<BaseLayout
  locale={lang}
  title={copy.pageTitle}
  description={copy.metaDescription}
  canonicalPath={`${prefix}/now/`}
  alternateLocales={buildHreflangAlternates('/now/')}
>
  <section class="hero">
    <h1>{copy.heroTitle}</h1>
    <p class="lede">{copy.heroLede}</p>
    <p class="updated-at">
      <span class="updated-label">{copy.updatedLabel}</span>
      <time datetime={new Date().toISOString()}>{updatedAt}</time>
    </p>
  </section>

  <section class="now-section now-dynamic" aria-labelledby="now-github-heading">
    <div class="dynamic-header">
      <div>
        <h2 id="now-github-heading">{copy.dynamic.githubHeading}</h2>
        <p class="dynamic-lede">
          {copy.dynamic.githubLede}
          {fromCache && <span class="cached-note">{copy.dynamic.cachedNote}</span>}
        </p>
      </div>
      <a
        class="dynamic-link"
        href={githubProfile.url}
        target="_blank"
        rel="noopener noreferrer"
      >
        {copy.dynamic.githubProfile} &rarr;
      </a>
    </div>
    <ol class="commit-list">
      {
        commits.map((commit) => (
          <li>
            <a class="commit-card glass-card" href={commit.html_url} target="_blank" rel="noopener noreferrer">
              <div class="commit-meta">
                <span class="commit-repo">{commit.repo}</span>
                <code class="commit-sha">{commit.sha}</code>
                <time datetime={commit.committed_at}>{formatCommitDate(commit.committed_at)}</time>
              </div>
              <p class="commit-message">{commit.message}</p>
            </a>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="now-section now-dynamic" aria-labelledby="now-toolkit-heading">
    <div class="dynamic-header">
      <div>
        <h2 id="now-toolkit-heading">{copy.dynamic.toolkitHeading}</h2>
        <p class="dynamic-lede">{copy.dynamic.toolkitLede}</p>
      </div>
      <a class="dynamic-link" href={`${prefix}/tools/`}>
        {copy.dynamic.toolkitLink} &rarr;
      </a>
    </div>
    <div class="tool-stack-grid">
      {
        toolStack.map((tool) => (
          <article class="tool-stack-card glass-card">
            <h3>
              <a href={tool.url} target="_blank" rel="noopener noreferrer">
                {tool.name}
              </a>
            </h3>
            <p>{tool.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  {
    copy.sections.map((section) => (
      <section class="now-section">
        <h2>{section.heading}</h2>
        <div class="now-grid">
          {section.items.map((item) => (
            <article class="now-card glass-card">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
              {item.link && (
                <a class="now-link" href={item.link.href}>
                  {item.link.text}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M5 12h14" />
                    <path d="m12 5 7 7-7 7" />
                  </svg>
                </a>
              )}
            </article>
          ))}
        </div>
      </section>
    ))
  }

  <p class="nownownow-cta">
    <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer">
      {copy.nownownowCta}
    </a>
  </p>
</BaseLayout>

<style>
  .updated-at {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    padding: 0.5rem 1rem;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--gradient-glass);
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .updated-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-secondary);
  }

  .now-section {
    margin-top: var(--space-xl);
  }

  .now-section h2 {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-line);
  }

  .now-dynamic h2 {
    margin-bottom: var(--space-sm);
    padding-bottom: 0;
    border-bottom: none;
  }

  .dynamic-header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .dynamic-lede {
    margin: 0;
    max-width: 42rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .cached-note {
    color: var(--color-secondary);
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .dynamic-link {
    align-self: end;
    font-weight: 600;
    white-space: nowrap;
    color: var(--color-primary);
  }

  .commit-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-sm);
  }

  .commit-card {
    display: grid;
    gap: var(--space-sm);
    padding: var(--space-md);
    color: inherit;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .commit-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .commit-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .commit-repo {
    font-weight: 700;
    color: var(--color-secondary);
  }

  .commit-sha {
    padding: 0.1rem 0.35rem;
    border-radius: var(--radius-sm);
    background: var(--color-soft-bg);
    font-size: 0.78rem;
  }

  .commit-message {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    overflow-wrap: anywhere;
  }

  .tool-stack-grid {
    display: grid;
    gap: var(--space-md);
  }

  .tool-stack-card {
    padding: var(--space-md);
    display: grid;
    gap: var(--space-sm);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tool-stack-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .tool-stack-card h3 {
    margin: 0;
    font-size: 1.05rem;
  }

  .tool-stack-card h3 a {
    color: inherit;
  }

  .tool-stack-card h3 a:hover {
    color: var(--color-primary);
  }

  .tool-stack-card p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .now-grid {
    display: grid;
    gap: var(--space-md);
  }

  @media (min-width: 640px) {
    .dynamic-header {
      align-items: end;
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .now-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .tool-stack-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 960px) {
    .now-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .tool-stack-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .now-card {
    padding: var(--space-lg);
    display: grid;
    gap: var(--space-sm);
    align-content: start;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .now-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    background: var(--color-surface-hover);
  }

  .now-card h3 {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.3;
  }

  .now-card p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.65;
  }

  .now-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: var(--space-sm);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .now-link:hover {
    color: var(--color-secondary);
  }

  .now-link svg {
    transition: transform 0.2s ease;
  }

  .now-link:hover svg {
    transform: translateX(3px);
  }

  .nownownow-cta {
    margin-top: var(--space-xl);
    text-align: center;
    font-size: 0.875rem;
  }

  .nownownow-cta a {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .nownownow-cta a:hover {
    color: var(--color-primary);
  }
</style>
