---
import { getCollection, render } from 'astro:content';
import ArticleChat from '@/components/ArticleChat.astro';
import Giscus from '@/components/Giscus.astro';
import SeriesNav from '@/components/SeriesNav.astro';
import SocialShare from '@/components/SocialShare.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import ArticleFooter from '@/components/ArticleFooter.astro';
import AffiliateCTA from '@/components/AffiliateCTA.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import EmailSignup from '@/components/EmailSignup.astro';
import ReaderFeedback from '@/components/ReaderFeedback.astro';
import {
  buildContentAlternateLocales,
  collectionPath,
  isLocale,
  localeFromId,
  stripLocaleFromId,
  ui,
} from '@/lib/i18n';
import {
  buildArticleSchema,
  buildBreadcrumbSchema,
  buildDynamicOgImagePath,
  buildFaqSchema,
  buildHowToSchema,
  buildReviewSchema,
  type JsonLdSchema,
} from '@/utils/seo';
import {
  estimateReadingMinutes,
  extractTocFromMarkdown,
  formatReadingTime,
} from '@/utils/reading';
import ReadingProgress from '@/components/ReadingProgress.astro';
import ArticleToc from '@/components/ArticleToc.astro';
import PagefindMeta from '@/components/PagefindMeta.astro';
import { siteConfig } from '@/config/site';
import { formatPageviews, getPlausiblePageviews } from '@/lib/plausible';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const postIds = posts.map((entry) => entry.id);
  const postPaths = new Map(
    posts.map((post) => {
      const lang = localeFromId(post.id);
      return [post.id, collectionPath(lang, 'blog', post.id)];
    })
  );
  const pageviewsByPath = await getPlausiblePageviews(Array.from(postPaths.values()));

  return posts.map((post) => {
    const lang = localeFromId(post.id);
    const canonicalPath = postPaths.get(post.id) ?? collectionPath(lang, 'blog', post.id);
    const relatedPosts = posts
      .filter((candidate) => candidate.id !== post.id && localeFromId(candidate.id) === lang)
      .map((candidate) => ({
        candidate,
        score:
          (candidate.data.series && candidate.data.series === post.data.series ? 10 : 0) +
          candidate.data.tags.filter((tag) => post.data.tags.includes(tag)).length,
      }))
      .filter(({ score }) => score > 0)
      .sort(({ candidate: left, score: leftScore }, { candidate: right, score: rightScore }) =>
        rightScore - leftScore || right.data.publishedAt.valueOf() - left.data.publishedAt.valueOf()
      )
      .slice(0, 5)
      .map(({ candidate }) => candidate);

    return {
      params: {
        lang,
        slug: stripLocaleFromId(post.id, lang)
      },
      props: {
        post,
        relatedPosts,
        alternateLocales: buildContentAlternateLocales('blog', post.id, postIds),
        pageviews: pageviewsByPath.get(canonicalPath) ?? null,
      }
    };
  });
}

const { post, relatedPosts, alternateLocales, pageviews } = Astro.props;
const { lang } = Astro.params;
if (!isLocale(lang)) {
  return Astro.redirect('/zh/blog/');
}

const { Content } = await render(post);
const canonicalPath = collectionPath(lang, 'blog', post.id);
const publishedTime = post.data.publishedAt.toISOString();
const modifiedTime = (post.data.updatedAt ?? post.data.publishedAt).toISOString();
const ogSection = post.data.contentType === 'review' ? 'review' : 'blog';
const customOgImage =
  post.data.ogImage && post.data.ogImage !== siteConfig.defaultOgImage
    ? post.data.ogImage
    : undefined;
const ogImage =
  customOgImage ??
  buildDynamicOgImagePath({
    title: post.data.title,
    description: post.data.description,
    section: ogSection,
    locale: lang,
    category: post.data.tags[0] ?? post.data.contentType,
  });
const faq = post.data.faq ?? [];
const copy = ui[lang];
const readingMinutes = estimateReadingMinutes(post.body ?? '');
const readingTimeLabel = formatReadingTime(readingMinutes, lang);
const pageviewsLabel =
  typeof pageviews === 'number'
    ? lang === 'zh'
      ? `${formatPageviews(pageviews, 'zh-CN')} 次阅读`
      : `${formatPageviews(pageviews, 'en-US')} views`
    : null;
const tocEntries = extractTocFromMarkdown(post.body ?? '');
const languageSwitchPath =
  alternateLocales.find(({ locale }) => locale !== lang)?.path ?? `/${lang === 'zh' ? 'en' : 'zh'}/blog/`;
const structuredData: JsonLdSchema[] = [
  buildArticleSchema({
    title: post.data.title,
    description: post.data.description,
    path: canonicalPath,
    locale: lang,
    publishedTime: post.data.publishedAt,
    modifiedTime: post.data.updatedAt,
    imagePath: ogImage,
  }),
  buildBreadcrumbSchema([
    { name: copy.siteTitle, path: `/${lang}/` },
    { name: copy.blog, path: `/${lang}/blog/` },
    { name: post.data.title, path: canonicalPath },
  ]),
  ...(faq.length > 0 ? [buildFaqSchema(faq)] : []),
  ...(post.data.howTo && post.data.howTo.length > 0
    ? [buildHowToSchema({ name: post.data.title, description: post.data.description, steps: post.data.howTo, imagePath: ogImage, locale: lang })]
    : []),
];

if (
  post.data.contentType === 'review' &&
  post.data.recommendation &&
  post.data.reviewedProduct
) {
  structuredData.push(
    buildReviewSchema({
      title: post.data.title,
      description: post.data.description,
      path: canonicalPath,
      publishedTime: post.data.publishedAt,
      rating: post.data.recommendation,
      itemReviewed: post.data.reviewedProduct,
    })
  );
}
---

<BaseLayout
  locale={lang}
  title={post.data.title}
  description={post.data.description}
  canonicalPath={canonicalPath}
  ogType="article"
  ogImage={ogImage}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  keywords={post.data.keywords}
  structuredData={structuredData}
  alternateLocales={alternateLocales}
  languageSwitchPath={languageSwitchPath}
>
  <ReadingProgress />
  <div class="article-layout">
    <ArticleToc locale={lang} entries={tocEntries} />
    <article class="article-main" data-pagefind-body>
      <PagefindMeta
        locale={lang}
        section="blog"
        contentType={post.data.contentType}
        tags={post.data.tags}
      />
      <p class="meta">{post.data.publishedAt.toISOString().slice(0, 10)}</p>
      <h1>{post.data.title}</h1>
      <p class="article-stats">
        <span>{readingTimeLabel}</span>
        {pageviewsLabel && <span>{pageviewsLabel}</span>}
      </p>
      <p class="lede">{post.data.description}</p>
      {
        post.data.tags.length > 0 && (
          <div class="tag-list">
            {post.data.tags.map((tag) => (
              <a class="tag-link" href={`/${lang}/tags/${encodeURIComponent(tag)}/`}>
                {tag}
              </a>
            ))}
          </div>
        )
      }
      <Content />
    {
      post.data.howTo && post.data.howTo.length > 0 && (
        <section class="how-to" aria-labelledby="how-to-title">
          <h2 id="how-to-title">{lang === 'zh' ? '操作步骤' : 'How to'}</h2>
          <ol>
            {post.data.howTo.map((step) => (
              <li>
                <h3>{step.name}</h3>
                <p>{step.text}</p>
                {step.url && (
                  <a href={step.url} target="_blank" rel="noopener noreferrer" class="step-link">
                    {lang === 'zh' ? '查看更多' : 'Learn more'}
                  </a>
                )}
              </li>
            ))}
          </ol>
        </section>
      )
    }
    {
      faq.length > 0 && (
        <section class="faq" aria-labelledby="faq-title">
          <h2 id="faq-title">{lang === 'zh' ? '常见问题' : 'Frequently asked questions'}</h2>
          <dl>
            {faq.map((item) => (
              <div>
                <dt>{item.question}</dt>
                <dd>{item.answer}</dd>
              </div>
            ))}
          </dl>
        </section>
      )
    }
    {
      post.data.contentType === 'review' && post.data.reviewedProduct && (
        <AffiliateCTA
          locale={lang}
          productName={post.data.reviewedProduct.name}
          productSlug={post.data.reviewedProduct.productSlug}
        />
      )
    }
    <RelatedPosts locale={lang} posts={relatedPosts} />
    <SeriesNav locale={lang} post={post} />
    <SocialShare title={post.data.title} url={Astro.url.href} />
    <ArticleFooter locale={lang} />
    </article>
  </div>
  <ArticleChat locale={lang} articleContent={post.body ?? ''} />
  <ReaderFeedback locale={lang} source={canonicalPath} compact />
  <EmailSignup locale={lang} />
  <EmailSignup locale={lang} variant="floating" />
  <Giscus locale={lang} />
</BaseLayout>

<script>
  const floatingSignup = document.getElementById('floating-signup');
  const DISMISS_KEY = 'newsletter_floating_dismissed';

  if (floatingSignup && !localStorage.getItem(DISMISS_KEY)) {
    let hasShown = false;

    const handleScroll = () => {
      if (hasShown) return;

      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const scrollPercent = (scrollTop / docHeight) * 100;

      if (scrollPercent > 50) {
        floatingSignup.classList.add('is-visible');
        hasShown = true;
        window.removeEventListener('scroll', handleScroll);
      }
    };

    const closeButton = floatingSignup.querySelector('[data-close-signup]');
    closeButton?.addEventListener('click', () => {
      localStorage.setItem(DISMISS_KEY, '1');
    });

    window.addEventListener('scroll', handleScroll, { passive: true });
  }
</script>

<style>
  .article-layout {
    display: grid;
    gap: 2rem;
    width: min(100%, 1100px);
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .article-layout {
      grid-template-columns: minmax(0, 720px) minmax(180px, 240px);
      justify-content: center;
      align-items: start;
    }

    .article-layout .article-main {
      grid-column: 1;
      grid-row: 1;
    }

    .article-layout .article-toc {
      grid-column: 2;
      grid-row: 1;
    }
  }

  .article-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    margin: -0.75rem 0 1.25rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .article-stats span + span::before {
    content: '';
    display: inline-block;
    width: 0.35rem;
    height: 0.35rem;
    margin: 0 0.65rem 0.12rem 0;
    border-radius: 999px;
    background: currentColor;
    opacity: 0.55;
  }

  .faq dl {
    display: grid;
    gap: 1rem;
  }

  .faq dl div {
    padding: 1.1rem 1.25rem;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--gradient-glass);
  }

  .faq dt {
    margin-bottom: 0.55rem;
    color: var(--color-heading);
    font-weight: 700;
  }

  .faq dd {
    color: var(--color-article);
    line-height: 1.7;
  }

  .how-to ol {
    display: grid;
    gap: 2rem;
    padding-left: 0;
    list-style: none;
    counter-reset: step;
  }

  .how-to li {
    position: relative;
    padding: 1.5rem;
    padding-left: 4rem;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--gradient-glass);
  }

  .how-to li::before {
    counter-increment: step;
    content: counter(step);
    position: absolute;
    left: 1.25rem;
    top: 1.5rem;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: white;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .how-to h3 {
    margin: 0 0 0.75rem;
    font-size: 1.25rem;
  }

  .how-to p {
    margin: 0;
    color: var(--color-article);
  }

  .step-link {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--color-primary);
    text-decoration: none;
  }

  .step-link:hover {
    text-decoration: underline;
  }
</style>
