---
import { getCollection, render } from 'astro:content';
import ArticleChat from '@/components/ArticleChat.astro';
import Giscus from '@/components/Giscus.astro';
import SeriesNav from '@/components/SeriesNav.astro';
import SocialShare from '@/components/SocialShare.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import EmailSignup from '@/components/EmailSignup.astro';
import ReaderFeedback from '@/components/ReaderFeedback.astro';
import {
  buildContentAlternateLocales,
  collectionPath,
  isLocale,
  localeFromId,
  stripLocaleFromId,
  ui,
} from '@/lib/i18n';
import {
  buildArticleSchema,
  buildBreadcrumbSchema,
  buildFaqSchema,
  buildReviewSchema,
  type JsonLdSchema,
} from '@/utils/seo';
import {
  estimateReadingMinutes,
  extractTocFromMarkdown,
  formatReadingTime,
} from '@/utils/reading';
import ReadingProgress from '@/components/ReadingProgress.astro';
import ArticleToc from '@/components/ArticleToc.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const postIds = posts.map((entry) => entry.id);

  return posts.map((post) => {
    const lang = localeFromId(post.id);
    const relatedPosts = posts
      .filter((candidate) => candidate.id !== post.id && localeFromId(candidate.id) === lang)
      .map((candidate) => ({
        candidate,
        score:
          (candidate.data.series && candidate.data.series === post.data.series ? 10 : 0) +
          candidate.data.tags.filter((tag) => post.data.tags.includes(tag)).length,
      }))
      .filter(({ score }) => score > 0)
      .sort(({ candidate: left, score: leftScore }, { candidate: right, score: rightScore }) =>
        rightScore - leftScore || right.data.publishedAt.valueOf() - left.data.publishedAt.valueOf()
      )
      .slice(0, 3)
      .map(({ candidate }) => candidate);

    return {
      params: {
        lang,
        slug: stripLocaleFromId(post.id, lang)
      },
      props: {
        post,
        relatedPosts,
        alternateLocales: buildContentAlternateLocales('blog', post.id, postIds)
      }
    };
  });
}

const { post, relatedPosts, alternateLocales } = Astro.props;
const { lang } = Astro.params;
if (!isLocale(lang)) {
  return Astro.redirect('/zh/blog/');
}

const { Content } = await render(post);
const canonicalPath = collectionPath(lang, 'blog', post.id);
const publishedTime = post.data.publishedAt.toISOString();
const modifiedTime = (post.data.updatedAt ?? post.data.publishedAt).toISOString();
const ogImage = post.data.ogImage;
const faq = post.data.faq ?? [];
const copy = ui[lang];
const readingMinutes = estimateReadingMinutes(post.body ?? '');
const readingTimeLabel = formatReadingTime(readingMinutes, lang);
const tocEntries = extractTocFromMarkdown(post.body ?? '');
const copyLabel = lang === 'zh' ? '复制' : 'Copy';
const copiedLabel = lang === 'zh' ? '已复制' : 'Copied';
const structuredData: JsonLdSchema[] = [
  buildArticleSchema({
    title: post.data.title,
    description: post.data.description,
    path: canonicalPath,
    locale: lang,
    publishedTime: post.data.publishedAt,
    modifiedTime: post.data.updatedAt,
    imagePath: ogImage,
  }),
  buildBreadcrumbSchema([
    { name: copy.siteTitle, path: `/${lang}/` },
    { name: copy.blog, path: `/${lang}/blog/` },
    { name: post.data.title, path: canonicalPath },
  ]),
  ...(faq.length > 0 ? [buildFaqSchema(faq)] : []),
];

if (
  post.data.contentType === 'review' &&
  post.data.recommendation &&
  post.data.reviewedProduct
) {
  structuredData.push(
    buildReviewSchema({
      title: post.data.title,
      description: post.data.description,
      path: canonicalPath,
      publishedTime: post.data.publishedAt,
      rating: post.data.recommendation,
      itemReviewed: post.data.reviewedProduct,
    })
  );
}
---

<BaseLayout
  locale={lang}
  title={post.data.title}
  description={post.data.description}
  canonicalPath={canonicalPath}
  ogType="article"
  ogImage={ogImage}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  structuredData={structuredData}
  alternateLocales={alternateLocales}
>
  <ReadingProgress />
  <div class="article-layout" data-copy-label={copyLabel} data-copied-label={copiedLabel}>
    <ArticleToc locale={lang} entries={tocEntries} />
    <article class="article-main" data-pagefind-body>
      <p class="meta">{post.data.publishedAt.toISOString().slice(0, 10)}</p>
      <h1>{post.data.title}</h1>
      <p class="reading-time">{readingTimeLabel}</p>
      <p class="lede">{post.data.description}</p>
      <Content />
    {
      faq.length > 0 && (
        <section class="faq" aria-labelledby="faq-title">
          <h2 id="faq-title">{lang === 'zh' ? '常见问题' : 'Frequently asked questions'}</h2>
          <dl>
            {faq.map((item) => (
              <div>
                <dt>{item.question}</dt>
                <dd>{item.answer}</dd>
              </div>
            ))}
          </dl>
        </section>
      )
    }
    <RelatedPosts locale={lang} posts={relatedPosts} />
    <SeriesNav locale={lang} post={post} />
    <SocialShare title={post.data.title} url={Astro.url.href} />
    </article>
  </div>
  <ArticleChat locale={lang} articleContent={post.body ?? ''} />
  <ReaderFeedback locale={lang} source={canonicalPath} compact />
  <EmailSignup locale={lang} />
  <Giscus locale={lang} />
</BaseLayout>

<script>
  const articleLayout = document.querySelector<HTMLElement>('.article-layout');
  const article = articleLayout?.querySelector('article[data-pagefind-body]');

  article?.querySelectorAll('pre').forEach((pre) => {
    const code = pre.querySelector('code');
    if (!code) return;

    const wrapper = document.createElement('div');
    wrapper.className = 'code-block';
    pre.parentNode?.insertBefore(wrapper, pre);
    wrapper.append(pre);

    const button = document.createElement('button');
    button.className = 'copy-code';
    button.type = 'button';
    button.textContent = articleLayout?.dataset.copyLabel ?? 'Copy';
    wrapper.append(button);

    button.addEventListener('click', async () => {
      await navigator.clipboard.writeText(code.textContent ?? '');
      button.textContent = articleLayout?.dataset.copiedLabel ?? 'Copied';
      button.dataset.copied = 'true';
      window.setTimeout(() => {
        button.textContent = articleLayout?.dataset.copyLabel ?? 'Copy';
        delete button.dataset.copied;
      }, 1600);
    });
  });
</script>

<style>
  .article-layout {
    display: grid;
    gap: 2rem;
    width: min(100%, 1100px);
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .article-layout {
      grid-template-columns: minmax(0, 720px) minmax(180px, 240px);
      justify-content: center;
      align-items: start;
    }

    .article-layout .article-main {
      grid-column: 1;
      grid-row: 1;
    }

    .article-layout .article-toc {
      grid-column: 2;
      grid-row: 1;
    }
  }

  .reading-time {
    margin: -0.75rem 0 1.25rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .faq dl {
    display: grid;
    gap: 1rem;
  }

  .faq dl div {
    padding: 1.1rem 1.25rem;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--gradient-glass);
  }

  .faq dt {
    margin-bottom: 0.55rem;
    color: var(--color-heading);
    font-weight: 700;
  }

  .faq dd {
    color: var(--color-article);
    line-height: 1.7;
  }

  :global(.code-block) {
    position: relative;
    margin: 2.5rem 0;
  }

  :global(article .code-block pre) {
    margin: 0;
    padding-top: 3rem;
  }

  :global(.copy-code) {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 1;
    padding: 0.35rem 0.65rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-text);
    font: 600 0.78rem var(--font-sans);
    cursor: pointer;
  }

  :global(.copy-code:hover),
  :global(.copy-code[data-copied='true']) {
    border-color: var(--color-primary);
    background: rgba(59, 130, 246, 0.2);
  }
</style>
