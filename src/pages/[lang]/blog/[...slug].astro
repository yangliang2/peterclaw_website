---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  buildContentAlternateLocales,
  collectionPath,
  isLocale,
  localeFromId,
  stripLocaleFromId,
  ui
} from '@/lib/i18n';
import { blogPostPath, findSeriesForPost, seriesPath } from '@/lib/series';
import { buildArticleSchema } from '@/utils/seo';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const postIds = posts.map((entry) => entry.id);

  return posts.map((post) => {
    const lang = localeFromId(post.id);

    return {
      params: {
        lang,
        slug: stripLocaleFromId(post.id, lang)
      },
      props: {
        post,
        alternateLocales: buildContentAlternateLocales('blog', post.id, postIds)
      }
    };
  });
}

const { post, alternateLocales } = Astro.props;
const { lang } = Astro.params;
if (!isLocale(lang)) {
  return Astro.redirect('/zh/blog/');
}

const { Content } = await render(post);
const canonicalPath = collectionPath(lang, 'blog', post.id);
const publishedTime = post.data.publishedAt.toISOString();
const modifiedTime = (post.data.updatedAt ?? post.data.publishedAt).toISOString();
const ogImage = post.data.ogImage;
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const currentSeries = findSeriesForPost(post, allPosts);
const otherSeriesPosts = currentSeries?.posts.filter((item) => item.id !== post.id) ?? [];
---

<BaseLayout
  locale={lang}
  title={post.data.title}
  description={post.data.description}
  canonicalPath={canonicalPath}
  ogType="article"
  ogImage={ogImage}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  structuredData={buildArticleSchema({
    title: post.data.title,
    description: post.data.description,
    path: canonicalPath,
    locale: lang,
    publishedTime: post.data.publishedAt,
    modifiedTime: post.data.updatedAt,
    imagePath: ogImage,
  })}
  alternateLocales={alternateLocales}
>
  <article>
    <p class="meta">{post.data.publishedAt.toISOString().slice(0, 10)}</p>
    <h1>{post.data.title}</h1>
    <p class="lede">{post.data.description}</p>
    <Content />
  </article>

  {
    currentSeries && otherSeriesPosts.length > 0 && (
      <nav class="series-nav" aria-labelledby="series-nav-title">
        <p class="meta">{currentSeries.title}</p>
        <h2 id="series-nav-title">{ui[lang].seriesOtherPosts}</h2>
        <div class="content-list">
          {otherSeriesPosts.map((item) => (
            <a class="content-item" href={blogPostPath(item)}>
              <span class="meta">
                {item.data.seriesOrder ? `#${item.data.seriesOrder}` : item.data.publishedAt.toISOString().slice(0, 10)}
              </span>
              <h3>{item.data.title}</h3>
            </a>
          ))}
        </div>
        <a class="series-link" href={seriesPath(lang, currentSeries.slug)}>
          {ui[lang].seriesViewAll}
        </a>
      </nav>
    )
  }
</BaseLayout>

<style>
  .series-nav {
    max-width: 720px;
    margin: 4rem auto 0;
    padding-top: 2rem;
    border-top: var(--border-glass);
  }

  .series-nav h2 {
    margin: 0;
    font-size: 1.75rem;
  }

  .series-link {
    display: inline-block;
    margin-top: 1.5rem;
    font-weight: 700;
  }
</style>
