---
import { getCollection, render } from 'astro:content';
import Giscus from '@/components/Giscus.astro';
import SocialShare from '@/components/SocialShare.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import EmailSignup from '@/components/EmailSignup.astro';
import ReaderFeedback from '@/components/ReaderFeedback.astro';
import {
  buildContentAlternateLocales,
  collectionPath,
  isLocale,
  localeFromId,
  stripLocaleFromId
} from '@/lib/i18n';
import { buildArticleSchema } from '@/utils/seo';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const postIds = posts.map((entry) => entry.id);

  return posts.map((post) => {
    const lang = localeFromId(post.id);

    return {
      params: {
        lang,
        slug: stripLocaleFromId(post.id, lang)
      },
      props: {
        post,
        alternateLocales: buildContentAlternateLocales('blog', post.id, postIds)
      }
    };
  });
}

const { post, alternateLocales } = Astro.props;
const { lang } = Astro.params;
if (!isLocale(lang)) {
  return Astro.redirect('/zh/blog/');
}

const { Content } = await render(post);
const canonicalPath = collectionPath(lang, 'blog', post.id);
const publishedTime = post.data.publishedAt.toISOString();
const modifiedTime = (post.data.updatedAt ?? post.data.publishedAt).toISOString();
const ogImage = post.data.ogImage;
---

<BaseLayout
  locale={lang}
  title={post.data.title}
  description={post.data.description}
  canonicalPath={canonicalPath}
  ogType="article"
  ogImage={ogImage}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  structuredData={buildArticleSchema({
    title: post.data.title,
    description: post.data.description,
    path: canonicalPath,
    locale: lang,
    publishedTime: post.data.publishedAt,
    modifiedTime: post.data.updatedAt,
    imagePath: ogImage,
  })}
  alternateLocales={alternateLocales}
>
  <article data-pagefind-body>
    <p class="meta">{post.data.publishedAt.toISOString().slice(0, 10)}</p>
    <h1>{post.data.title}</h1>
    <p class="lede">{post.data.description}</p>
    {post.data.tags && post.data.tags.length > 0 && (
      <div class="tag-row">
        {post.data.tags.map((tag) => (
          <a class="tag-pill" href={`/${lang}/blog/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
        ))}
      </div>
    )}
    <Content />
    <SocialShare title={post.data.title} url={Astro.url.href} />
  </article>

  <style>
    .tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 2rem;
    }
    .tag-pill {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.85rem;
      font-weight: 500;
      background: var(--color-soft-bg);
      color: var(--color-text-muted);
      border: 1px solid var(--color-line);
      text-decoration: none;
      transition: all 0.2s ease;
    }
    .tag-pill:hover {
      background: var(--color-primary-soft-bg);
      color: var(--color-primary);
      border-color: var(--color-primary);
    }
  </style>
  <ReaderFeedback locale={lang} source={canonicalPath} compact />
  <EmailSignup locale={lang} />
  <Giscus locale={lang} />
</BaseLayout>
