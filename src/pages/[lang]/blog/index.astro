---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { collectionPath, isLocale, localeFromId, ui } from '@/lib/i18n';

export function getStaticPaths() {
  return ['zh', 'en'].map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang)) {
  return Astro.redirect('/zh/blog/');
}

const copy = ui[lang];
const posts = (await getCollection('blog', (entry) => localeFromId(entry.id) === lang && !entry.data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
---

<BaseLayout locale={lang} title={copy.blog} canonicalPath={`/${lang}/blog/`}>
  <h1>{copy.blog}</h1>
  <div class="content-list">
    {
      posts.map((post) => (
        <a class="content-item" href={collectionPath(lang, 'blog', post.id)}>
          <span class="meta">{post.data.publishedAt.toISOString().slice(0, 10)}</span>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="tag-row">
              {post.data.tags.map((tag) => (
                <span class="tag-pill">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))
    }
  </div>

  <style>
    .tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }
    .tag-pill {
      display: inline-block;
      padding: 0.2rem 0.6rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 500;
      background: var(--color-soft-bg);
      color: var(--color-text-muted);
      border: 1px solid var(--color-line);
    }
  </style>
</BaseLayout>
