---
import { getCollection } from 'astro:content';
import BlogPostCard from '@/components/BlogPostCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { collectionPath, isLocale, localeFromId, ui } from '@/lib/i18n';
import { buildBreadcrumbSchema } from '@/utils/seo';

export function getStaticPaths() {
  return ['zh', 'en'].map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang)) {
  return Astro.redirect('/zh/blog/');
}

const copy = ui[lang];
const posts = (await getCollection('blog', (entry) => localeFromId(entry.id) === lang && !entry.data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
---

<BaseLayout
  locale={lang}
  title={copy.blog}
  canonicalPath={`/${lang}/blog/`}
  structuredData={buildBreadcrumbSchema([
    { name: copy.siteTitle, path: `/${lang}/` },
    { name: copy.blog, path: `/${lang}/blog/` },
  ])}
>
  <h1>{copy.blog}</h1>
  <div class="blog-post-grid">
    {posts.map((post) => (
      <BlogPostCard post={post} locale={lang} href={collectionPath(lang, 'blog', post.id)} />
    ))}
  </div>
</BaseLayout>

<style>
  .blog-post-grid {
    display: grid;
    gap: 1.5rem;
    margin-top: 2rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .blog-post-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .blog-post-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
