---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { toolsCopy, toolsLastUpdated } from '@/config/tools';
import { buildHreflangAlternates, isLocale, ui } from '@/lib/i18n';
import { buildBreadcrumbSchema, buildItemListSchema, type JsonLdSchema } from '@/utils/seo';

export function getStaticPaths() {
  return ['zh', 'en'].map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang)) {
  return Astro.redirect('/zh/tools/');
}

const copy = toolsCopy[lang];
const siteCopy = ui[lang];
const prefix = `/${lang}`;

const updatedAt = new Date(toolsLastUpdated).toLocaleDateString(
  lang === 'zh' ? 'zh-CN' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
);

function ratingValue(rating: string): number {
  return Number.parseFloat(rating);
}

const toolsListSchema = buildItemListSchema({
  name: copy.heroTitle,
  description: copy.metaDescription,
  path: `${prefix}/tools/`,
  items: copy.categories.flatMap((category) =>
    category.items.map((tool) => ({
      name: tool.name,
      description: tool.description,
      url: tool.url,
    }))
  ),
});

const structuredData: JsonLdSchema[] = [
  toolsListSchema,
  buildBreadcrumbSchema([
    { name: siteCopy.siteTitle, path: `${prefix}/` },
    { name: siteCopy.tools, path: `${prefix}/tools/` },
  ]),
];
---

<BaseLayout
  locale={lang}
  title={copy.pageTitle}
  description={copy.metaDescription}
  canonicalPath={`${prefix}/tools/`}
  alternateLocales={buildHreflangAlternates('/tools/')}
  structuredData={structuredData}
>
  <section class="hero">
    <h1>{copy.heroTitle}</h1>
    <p class="lede">{copy.heroLede}</p>
  </section>

  {
    copy.categories.map((category) => (
      <section class="tools-category">
        <h2>{category.title}</h2>
        <div class="tools-grid">
          {category.items.map((tool) => {
            const ratingRaw = Number(tool.rating);
            const rating = Number.isFinite(ratingRaw) ? ratingRaw : 0;
            const starCount = Math.max(0, Math.min(5, Math.floor(rating)));
            const hasHalf = rating % 1 >= 0.5;
            const stars = "★".repeat(starCount) + (hasHalf ? "½" : "");

            return (
              <article class="tool-card glass-card">
                <div class="tool-header">
                  <h3>
                    <a href={tool.url} target="_blank" rel="noopener noreferrer">
                      {tool.name}
                    </a>
                  </h3>
                  <div class="tool-rating" title={`${copy.ratingLabel}: ${rating}/5.0`}>
                    <span class="rating-value">{rating.toFixed(1)}</span>
                    <span class="rating-stars">{stars}</span>
                  </div>
                </div>
                <p class="tool-rating">
                  <span class="tool-rating-label">{copy.ratingLabel}</span>
                  <span class="tool-rating-value" aria-label={`${copy.ratingLabel}: ${rating}`}>
                    {rating}
                  </span>
                </p>
                <p class="tool-description">{tool.description}</p>
                <p class="tool-review">{tool.review}</p>
                {tool.reviewLink && (
                  <a class="tool-review-link" href={tool.reviewLink}>
                    {copy.reviewLinkLabel}
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M5 12h14" />
                      <path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                )}
              </article>
            );
          })}
        </div>
      </section>
    ))
  }

  <p class="disclaimer">{copy.disclaimer}</p>

  <p class="last-updated">
    <span class="last-updated-label">{copy.lastUpdatedLabel}</span>
    <time datetime={toolsLastUpdated}>{updatedAt}</time>
  </p>
</BaseLayout>

<script>
  document.addEventListener('click', (event) => {
    const link = (event.target as HTMLElement).closest<HTMLAnchorElement>('a[href^="/go/"]');
    if (!link) return;

    const slug = link.pathname.split('/').filter(Boolean).at(-1);
    window.trackEvent?.('affiliate_link_click', {
      slug,
      label: link.innerText.trim(),
      source: 'tools',
    });
  });
</script>

<style>
  .tools-category {
    margin-top: var(--space-xl);
  }

  .tools-category h2 {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-line);
  }

  .tools-grid {
    display: grid;
    gap: var(--space-md);
  }

  @media (min-width: 640px) {
    .tools-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .tool-card {
    padding: var(--space-lg);
    display: grid;
    gap: var(--space-sm);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tool-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    background: var(--color-surface-hover);
  }

  .tool-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .tool-header h3 {
    margin: 0;
    font-size: 1.25rem;
  }

  .tool-header h3 a {
    color: var(--color-heading);
  }

  .tool-header h3 a:hover {
    color: var(--color-primary);
  }

  .tool-header svg {
    flex-shrink: 0;
    color: var(--color-text-muted);
  }

  .tool-rating {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    font-size: 0.875rem;
  }

  .tool-rating-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-secondary);
  }

  .tool-rating-value {
    font-weight: 600;
    color: var(--color-primary);
    font-variant-numeric: tabular-nums;
  }

  .tool-description {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  .tool-review {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-text);
  }

  .tool-footer {
    display: grid;
    gap: var(--space-sm);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-line);
  }

  .tool-review-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: var(--space-xs);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
    width: fit-content;
  }

  .tool-review-link:hover {
    text-decoration: underline;
  }

  .disclaimer {
    margin-top: var(--space-xl);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  .last-updated {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: var(--space-xl) auto 0;
    padding: 0.5rem 1rem;
    border: var(--border-glass);
    border-radius: var(--radius-md);
    background: var(--gradient-glass);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    justify-content: center;
  }

  .last-updated-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-secondary);
  }
</style>
