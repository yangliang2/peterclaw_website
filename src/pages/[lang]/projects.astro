---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { projects, projectsCopy, projectTags } from '@/config/projects';
import { buildHreflangAlternates, isLocale } from '@/lib/i18n';

export function getStaticPaths() {
  return ['zh', 'en'].map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang)) {
  return Astro.redirect('/zh/projects/');
}

const copy = projectsCopy[lang];
const prefix = `/${lang}`;

const getDemoHref = (demo: (typeof projects)[number]['demo']) => {
  if (!demo) {
    return undefined;
  }

  return typeof demo === 'string' ? demo : demo[lang];
};
---

<BaseLayout
  locale={lang}
  title={copy.pageTitle}
  description={copy.metaDescription}
  canonicalPath={`${prefix}/projects/`}
  alternateLocales={buildHreflangAlternates('/projects/')}
>
  <section class="hero">
    <h1>{copy.heroTitle}</h1>
    <p class="lede">{copy.heroLede}</p>
  </section>

  <section class="projects-section" aria-labelledby="projects-heading">
    <div class="section-header">
      <h2 id="projects-heading">{copy.pageTitle}</h2>
      <div class="filters" aria-label={copy.filtersLabel}>
        <button class="filter is-active" type="button" data-filter="all" aria-pressed="true">{copy.all}</button>
        {projectTags.map((tag) => <button class="filter" type="button" data-filter={tag} aria-pressed="false">{tag}</button>)}
      </div>
    </div>

    <div class="projects-grid">
      {
        projects.map((project) => (
          <article class="project-card glass-card" data-tags={project.tags.join(' ')} data-github-repo={project.githubRepo}>
            <div class="project-main">
              <div>
                <p class="project-tags">{project.tags.join(' / ')}</p>
                <h3>{project.name}</h3>
              </div>
              <p>{project.description[lang]}</p>
            </div>

            {
              project.githubRepo && (
                <div class="github-stats" data-github-stats aria-live="polite">
                  <p class="github-stats-loading">{copy.githubStatsLoading}</p>
                  <dl hidden>
                    <div>
                      <dt>{copy.stars}</dt>
                      <dd data-stat="stars"></dd>
                    </div>
                    <div>
                      <dt>{copy.forks}</dt>
                      <dd data-stat="forks"></dd>
                    </div>
                    <div>
                      <dt>{copy.language}</dt>
                      <dd class="language" data-stat="language"></dd>
                    </div>
                    <div>
                      <dt>{copy.updated}</dt>
                      <dd data-stat="updated"></dd>
                    </div>
                  </dl>
                </div>
              )
            }

            <div class="stack">
              <span>{copy.stack}</span>
              <ul>
                {project.stack.map((item) => <li>{item}</li>)}
              </ul>
            </div>

            <div class="project-links">
              {project.github && <a class="btn btn-secondary" href={project.github}>{copy.github}</a>}
              {getDemoHref(project.demo) && <a class="btn btn-primary" href={getDemoHref(project.demo)}>{copy.demo}</a>}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <script>
    interface RepositoryStats {
      repo: string;
      stars: number;
      forks: number;
      language: string | null;
      updatedAt: string;
    }

    const languageColors: Record<string, string> = {
      Astro: '#ff5d01',
      CSS: '#563d7c',
      JavaScript: '#f1e05a',
      TypeScript: '#3178c6',
      Python: '#3572a5',
      Go: '#00add8',
      Rust: '#dea584',
      Vue: '#41b883',
    };

    const locale = document.documentElement.lang === 'en' ? 'en' : 'zh-CN';
    const numberFormatter = new Intl.NumberFormat(locale, { notation: 'compact', maximumFractionDigits: 1 });
    const dateFormatter = new Intl.DateTimeFormat(locale, { dateStyle: 'medium' });
    const filters = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter]'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-tags]'));

    fetch('/api/github-projects')
      .then((response) => {
        if (!response.ok) {
          throw new Error('GitHub API request failed');
        }

        return response.json() as Promise<{ repositories: RepositoryStats[] }>;
      })
      .then(({ repositories }) => {
        const statsByRepository = new Map(repositories.map((repository) => [repository.repo, repository]));

        cards.forEach((card) => {
          const repository = card.dataset.githubRepo && statsByRepository.get(card.dataset.githubRepo);
          const stats = card.querySelector<HTMLElement>('[data-github-stats]');

          if (!repository || !stats) {
            return;
          }

          const stars = stats.querySelector<HTMLElement>('[data-stat="stars"]');
          const forks = stats.querySelector<HTMLElement>('[data-stat="forks"]');
          const language = stats.querySelector<HTMLElement>('[data-stat="language"]');
          const updated = stats.querySelector<HTMLElement>('[data-stat="updated"]');

          if (!stars || !forks || !language || !updated) {
            return;
          }

          stars.textContent = `\u2605 ${numberFormatter.format(repository.stars)}`;
          forks.textContent = numberFormatter.format(repository.forks);
          language.textContent = repository.language ?? '-';
          language.style.setProperty('--language-color', languageColors[repository.language ?? ''] ?? '#8b949e');
          updated.textContent = dateFormatter.format(new Date(repository.updatedAt));
          stats.querySelector('.github-stats-loading')?.remove();
          stats.querySelector('dl')?.removeAttribute('hidden');
        });
      })
      .catch(() => {
        document.querySelectorAll<HTMLElement>('[data-github-stats]').forEach((element) => {
          element.hidden = true;
        });
      });

    filters.forEach((filter) => {
      filter.addEventListener('click', () => {
        const selected = filter.dataset.filter ?? 'all';

        filters.forEach((item) => {
          const active = item === filter;
          item.classList.toggle('is-active', active);
          item.setAttribute('aria-pressed', String(active));
        });

        cards.forEach((card) => {
          const tags = card.dataset.tags?.split(' ') ?? [];
          card.hidden = selected !== 'all' && !tags.includes(selected);
        });
      });
    });
  </script>
</BaseLayout>

<style>
  .projects-section {
    margin-top: var(--space-xl);
  }

  .section-header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .section-header h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .filter {
    min-height: 2.5rem;
    padding: 0.55rem 0.9rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    background: var(--color-soft-bg);
    color: var(--color-text-muted);
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter:hover,
  .filter.is-active {
    border-color: var(--color-primary);
    background: var(--color-primary-soft-bg);
    color: var(--color-text);
  }

  .projects-grid {
    display: grid;
    gap: var(--space-md);
  }

  .project-card {
    display: grid;
    gap: var(--space-lg);
    padding: var(--space-lg);
  }

  .project-main {
    display: grid;
    gap: var(--space-md);
  }

  .project-main h3 {
    margin: 0;
    font-size: clamp(1.35rem, 3vw, 1.8rem);
  }

  .project-main p:last-child {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .project-tags {
    margin: 0 0 var(--space-sm);
    color: var(--color-secondary);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .stack {
    display: grid;
    gap: var(--space-sm);
  }

  .github-stats {
    min-height: 4.9rem;
  }

  .github-stats-loading {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .github-stats dl {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    padding: var(--space-sm) 0;
    margin: 0;
    border-block: 1px solid var(--color-line);
  }

  .github-stats dt {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .github-stats dd {
    margin: 0.25rem 0 0;
    color: var(--color-text);
    font-size: 0.93rem;
    font-weight: 600;
  }

  .github-stats .language {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .github-stats .language::before {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: var(--language-color, #8b949e);
    content: '';
  }

  .stack span {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
  }

  .stack ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .stack li {
    padding: 0.35rem 0.65rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    background: var(--color-soft-bg);
    font-size: 0.9rem;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .project-links .btn {
    min-width: 7rem;
  }

  @media (min-width: 760px) {
    .section-header {
      align-items: center;
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .projects-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .project-card {
      min-height: 24rem;
      align-content: space-between;
    }
  }
</style>
