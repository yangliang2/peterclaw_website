---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { projects, projectsCopy, projectTags } from '@/config/projects';
import { getProjectRepositoryStats } from '@/lib/github';
import { buildHreflangAlternates, isLocale } from '@/lib/i18n';
import { absoluteUrl } from '@/utils/seo';

export function getStaticPaths() {
  return ['zh', 'en'].map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang)) {
  return Astro.redirect('/zh/projects/');
}

const copy = projectsCopy[lang];
const prefix = `/${lang}`;
const { repositories: githubRepositories } = await getProjectRepositoryStats();
const githubStatsByRepository = new Map(
  githubRepositories.map((repository) => [repository.repo, repository])
);

function projectUrlForSchema(url: string | Record<string, string>) {
  const value = typeof url === 'string' ? url : url[lang];
  return value.startsWith('http') ? value : absoluteUrl(value);
}

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: copy.pageTitle,
  description: copy.metaDescription,
  url: absoluteUrl(`${prefix}/projects/`),
  itemListElement: projects.map((project, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@type': 'SoftwareApplication',
      name: project.title,
      description: project.description[lang],
      url: projectUrlForSchema(project.url),
      applicationCategory: 'DeveloperApplication',
    },
  })),
};
---

<BaseLayout
  locale={lang}
  title={copy.pageTitle}
  description={copy.metaDescription}
  canonicalPath={`${prefix}/projects/`}
  alternateLocales={buildHreflangAlternates('/projects/')}
  structuredData={itemListSchema}
>
  <section class="hero">
    <h1>{copy.heroTitle}</h1>
    <p class="lede">{copy.heroLede}</p>
  </section>

  <section class="projects-section" aria-labelledby="projects-heading">
    <div class="section-header">
      <h2 id="projects-heading">{copy.pageTitle}</h2>
      <div class="filters" role="group" aria-label={copy.filtersLabel}>
        <button class="filter is-active" type="button" data-filter="all" aria-pressed="true">{copy.all}</button>
        {projectTags.map((tag) => <button class="filter" type="button" data-filter={tag} aria-pressed="false">{tag}</button>)}
      </div>
    </div>

    <div class="projects-grid">
      {
        projects.map((project) => (
          <ProjectCard
            project={project}
            locale={lang}
            copy={copy}
            githubStats={project.githubRepo ? githubStatsByRepository.get(project.githubRepo) : undefined}
          />
        ))
      }
    </div>
  </section>

  <script>
    const filters = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter]'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-tags]'));

    filters.forEach((filter) => {
      filter.addEventListener('click', () => {
        const selected = filter.dataset.filter ?? 'all';

        filters.forEach((item) => {
          const active = item === filter;
          item.classList.toggle('is-active', active);
          item.setAttribute('aria-pressed', String(active));
        });

        cards.forEach((card) => {
          const tags = card.dataset.tags?.split(' ') ?? [];
          card.hidden = selected !== 'all' && !tags.includes(selected);
        });
      });
    });
  </script>
</BaseLayout>

<style>
  .projects-section {
    margin-top: var(--space-xl);
  }

  .section-header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .section-header h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .filter {
    min-height: 2.5rem;
    padding: 0.55rem 0.9rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    background: var(--color-soft-bg);
    color: var(--color-text-muted);
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter:hover,
  .filter.is-active {
    border-color: var(--color-primary);
    background: var(--color-primary-soft-bg);
    color: var(--color-text);
  }

  .projects-grid {
    display: grid;
    gap: var(--space-md);
    grid-template-columns: minmax(0, 1fr);
  }

  @media (min-width: 760px) {
    .section-header {
      align-items: center;
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .projects-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1200px) {
    .projects-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
