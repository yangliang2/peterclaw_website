---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { blogPostPath, buildSeries, seriesPath } from '@/lib/series';
import { isLocale, localeFromId, ui } from '@/lib/i18n';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const series = buildSeries(posts);

  return series.map((item) => ({
    params: {
      lang: item.locale,
      slug: item.slug,
    },
    props: {
      series: item,
    },
  }));
}

const { series } = Astro.props;
const { lang } = Astro.params;
if (!isLocale(lang) || localeFromId(series.posts[0].id) !== lang) {
  return Astro.redirect('/zh/blog/');
}

const copy = ui[lang];
const description =
  lang === 'zh'
    ? `${series.title}专题合集，共 ${series.posts.length} 篇文章。`
    : `${series.title} series collection with ${series.posts.length} posts.`;
---

<BaseLayout locale={lang} title={series.title} description={description} canonicalPath={seriesPath(lang, series.slug)}>
  <section class="series-hero">
    <a class="meta" href={`/${lang}/blog/`}>{copy.blog}</a>
    <h1>{series.title}</h1>
    <p class="lede">{description}</p>
  </section>

  <ol class="series-timeline">
    {
      series.posts.map((post, index) => (
        <li>
          <a class="content-item" href={blogPostPath(post)}>
            <span class="meta">
              {post.data.seriesOrder ? `#${post.data.seriesOrder}` : `#${index + 1}`} ·{' '}
              {post.data.publishedAt.toISOString().slice(0, 10)}
            </span>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
          </a>
        </li>
      ))
    }
  </ol>
</BaseLayout>

<style>
  .series-hero {
    padding: 3rem 0 2rem;
  }

  .series-timeline {
    display: grid;
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
